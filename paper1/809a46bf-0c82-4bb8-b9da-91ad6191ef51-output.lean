open Real

def T3 (t c k γ : ℝ) : ℝ := 2 - 3*t*γ + 3*c*γ^2 - k*γ^3

def task_compat (t c k γ_star : ℝ) : ℝ := T3 t c k γ_star / 2

theorem compat_lt_one_iff (t c k γ_star : ℝ) (hT : T3 t c k γ_star > 0) :
    task_compat t c k γ_star < 1 ↔ T3 t c k γ_star < 2 := by
