def γ_NF (t c k : ℝ) : ℝ := (3*c + Real.sqrt (9*c^2 - 12*k*t)) / (2*k)

def stab_margin (γ_star t c k : ℝ) : ℝ := γ_NF t c k - γ_star

theorem T3_factor (t c k γ : ℝ) :
    T3 t c k γ - 2 = -γ * (k*γ^2 - 3*c*γ + 3*t) := by unfold T3; ring

