set_option maxRecDepth 4000
set_option synthInstance.maxHeartbeats 20000
set_option synthInstance.maxSize 128

set_option relaxedAutoImplicit false
set_option autoImplicit false

noncomputable section

noncomputable def T3 (t0 c γ : ℝ) : ℝ := t0 - γ * c

noncomputable def D3 (D0 t3 d3 γ : ℝ) : ℝ := D0 * (1 - γ * t3 + γ ^ 2 * d3)

noncomputable def Delta3 (t0 c D0 t3 d3 γ : ℝ) : ℝ :=
  T3 t0 c γ ^ 2 - 4 * D3 D0 t3 d3 γ

noncomputable def rho3 (T Δ : ℝ) : ℝ := (T + Real.sqrt Δ) / 2

lemma rho3_ge_half_T (T Δ : ℝ) (hΔ : 0 ≤ Δ) : T / 2 ≤ rho3 T Δ := by
  unfold rho3; linarith [Real.sqrt_nonneg Δ]

lemma rho3_eq_half_T_iff (T Δ : ℝ) (hΔ : 0 ≤ Δ) :
    rho3 T Δ = T / 2 ↔ Δ = 0 := by
  unfold rho3
  constructor
  · intro h
    have : Real.sqrt Δ = 0 := by linarith
    exact Real.sqrt_eq_zero hΔ |>.mp this
  · intro h; rw [h]; simp

lemma rho3_strict_mono_T (Δ : ℝ) (hΔ : 0 ≤ Δ) :
    StrictMono (fun T => rho3 T Δ) := by
  intro T₁ T₂ h; unfold rho3; linarith

lemma rho3_mono_Delta (T : ℝ) : Monotone (fun Δ => rho3 T Δ) := by
  intro Δ₁ Δ₂ h
  unfold rho3
  have := Real.sqrt_le_sqrt h
  linarith

lemma delta3_zero_at_critical
    (t0 c D0 t3 d3 lam : ℝ)
    (hlam : lam > 0)
    -- The critical point γ* = 1/lam satisfies T(γ*)² = 4D(γ*)
    -- This encodes: c = lam · t0/ρ₂* (from Rayleigh quotient structure)
    -- We state it as a hypothesis since it depends on M₂* structure
    (h_boundary : T3 t0 c (1/lam) ^ 2 = 4 * D3 D0 t3 d3 (1/lam)) :
    Delta3 t0 c D0 t3 d3 (1/lam) = 0 := by
  unfold Delta3; linarith

lemma delta3_polynomial (t0 c D0 t3 d3 γ : ℝ) :
    Delta3 t0 c D0 t3 d3 γ =
    (c^2 - 4*D0*d3) * γ^2 + (-2*t0*c + 4*D0*t3) * γ + (t0^2 - 4*D0) := by
  unfold Delta3 T3 D3; ring

lemma delta3_pos_away_from_zero
    (t0 c D0 t3 d3 γstar : ℝ)
    (h_nonneg : ∀ γ, Delta3 t0 c D0 t3 d3 γ ≥ 0)
    (h_zero : Delta3 t0 c D0 t3 d3 γstar = 0)
    (h_leading : c^2 - 4*D0*d3 > 0)  -- leading coeff positive
    (γ : ℝ) (hne : γ ≠ γstar) :
    Delta3 t0 c D0 t3 d3 γ > 0 := by
      have h_quad_pos : ∀ γ, γ ≠ γstar → Delta3 t0 c D0 t3 d3 γ > 0 := by
        intro γ hne
        have h_quad_form : Delta3 t0 c D0 t3 d3 γ = (c^2 - 4*D0*d3) * (γ - γstar)^2 + Delta3 t0 c D0 t3 d3 γstar := by
          -- By definition of $Delta3$, we can expand both sides and simplify.
          simp [Delta3, T3, D3] at *;
          -- By comparing coefficients, we can see that the equations are equivalent.
          have h_coeff : -2 * t0 * c + 4 * D0 * t3 = (c^2 - 4 * D0 * d3) * (-2 * γstar) := by
            have h_deriv_zero : deriv (fun γ => (t0 - γ * c)^2 - 4 * (D0 * (1 - γ * t3 + γ^2 * d3))) γstar = 0 := by
              exact IsLocalMin.deriv_eq_zero ( Filter.Eventually.of_forall fun x => by norm_num; linarith [ h_nonneg x ] );
            norm_num at h_deriv_zero; linarith;
          grind
        exact h_quad_form.symm ▸ by nlinarith [ mul_self_pos.mpr ( sub_ne_zero.mpr hne ) ] ;
      exact h_quad_pos γ hne

lemma T3_antitone (t0 c : ℝ) (hc : 0 < c) :
    StrictAnti (fun γ => T3 t0 c γ) := by
  intro γ₁ γ₂ h
  unfold T3; nlinarith

lemma rho3_ge_rho_star_when_T_larger
    (t0 c D0 t3 d3 γstar γ : ℝ)
    (hc : 0 < c) (hD0 : 0 < D0)
    (h_delta_zero : Delta3 t0 c D0 t3 d3 γstar = 0)
    (h_delta_nonneg : ∀ g, 0 ≤ Delta3 t0 c D0 t3 d3 g)
    (h_T_ge : T3 t0 c γstar ≤ T3 t0 c γ) :
    rho3 (T3 t0 c γstar) (Delta3 t0 c D0 t3 d3 γstar) ≤
    rho3 (T3 t0 c γ) (Delta3 t0 c D0 t3 d3 γ) := by
      -- Since $T3 t0 c γstar \leq T3 t0 c γ$, we have $rho3 (T3 t0 c γstar) 0 \leq rho3 (T3 t0 c γ) (Delta3 t0 c D0 t3 d3 γ)$ by the monotonicity of $rho3$ in $T$.
      simp [rho3, h_delta_zero] at *;
      -- Since $\sqrt{\Delta3}$ is non-negative, adding it to $T3$ preserves the inequality.
      have h_sqrt_nonneg : 0 ≤ Real.sqrt (Delta3 t0 c D0 t3 d3 γ) := by
        -- Since the square root function is non-negative for non-negative inputs, we have:
        apply Real.sqrt_nonneg
      linarith [h_T_ge, h_sqrt_nonneg]

lemma sqrt_delta_ge_T_diff
    (t0 c D0 t3 d3 γstar γ : ℝ)
    (hc : 0 < c)
    (h_delta_perfect_sq : ∀ g, Delta3 t0 c D0 t3 d3 g =
                               (c^2 - 4*D0*d3) * (g - γstar)^2)
    (h_leading_ge : c^2 ≤ c^2 - 4*D0*d3) :
    T3 t0 c γstar - T3 t0 c γ ≤
    Real.sqrt (Delta3 t0 c D0 t3 d3 γ) := by
      -- By definition of $Delta3$, we know that $Delta3 t0 c D0 t3 d3 γ = (c^2 - 4 * D0 * d3) * (γ - γstar)^2$.
      have h_delta_def : Delta3 t0 c D0 t3 d3 γ = (c^2 - 4 * D0 * d3) * (γ - γstar)^2 := by
        -- Apply the hypothesis `h_delta_perfect_sq` to `γ`.
        apply h_delta_perfect_sq;
      -- Substitute the definitions of T3 into the inequality.
      have h_sub : T3 t0 c γstar - T3 t0 c γ = c * (γ - γstar) := by
        unfold T3; ring;
      exact h_sub.symm ▸ Real.le_sqrt_of_sq_le ( by nlinarith )

lemma delta3_eq_sq_of_zero
    (t0 c D0 t3 d3 γstar : ℝ)
    (hγstar : 0 < γstar)
    (h_zero : Delta3 t0 c D0 t3 d3 γstar = 0)
    (h_nonneg : ∀ γ, 0 < γ → Delta3 t0 c D0 t3 d3 γ ≥ 0) :
    ∀ γ, Delta3 t0 c D0 t3 d3 γ = (c^2 - 4*D0*d3) * (γ - γstar)^2 := by
      -- By definition of $Delta3$, we can expand it as a quadratic polynomial in $\gamma$.
      have h_expand : ∀ γ, Delta3 t0 c D0 t3 d3 γ = (c^2 - 4 * D0 * d3) * γ^2 + (-2 * t0 * c + 4 * D0 * t3) * γ + (t0^2 - 4 * D0) := by
        exact?;
      have h_deriv_zero : ∀ γ, deriv (fun γ => Delta3 t0 c D0 t3 d3 γ) γ = 2 * (c^2 - 4 * D0 * d3) * γ + (-2 * t0 * c + 4 * D0 * t3) := by
        norm_num [ h_expand, mul_assoc, mul_comm, mul_left_comm ];
      have h_deriv_zero_at_gamma_star : deriv (fun γ => Delta3 t0 c D0 t3 d3 γ) γstar = 0 := by
        exact IsLocalMin.deriv_eq_zero ( Filter.eventually_of_mem ( Ioi_mem_nhds hγstar ) fun γ hγ => by aesop );
      grind

theorem conj_e_global_optimality
    -- Scalar invariants of the K=3 system
    (t0 c D0 t3 d3 : ℝ)
    -- Positivity conditions
    (ht0 : 0 < t0) (hc : 0 < c) (hD0 : 0 < D0)
    (ht3 : 0 < t3) (hd3 : 0 < d3)
    -- λ = Rayleigh quotient ⟨Σ₃v*,v*⟩ > 0
    (lam : ℝ) (hlam : 0 < lam)
    -- γ* = 1/λ is the critical point
    (γstar : ℝ) (hγstar : γstar = 1 / lam)
    -- Δ(γ*) = 0: the boundary condition
    (h_delta_zero : Delta3 t0 c D0 t3 d3 γstar = 0)
    -- For γ ≠ γ* in the feasible set, Δ(γ) ≥ 0
    (h_delta_nonneg : ∀ γ : ℝ, 0 < γ → 0 ≤ Delta3 t0 c D0 t3 d3 γ)
    -- For γ ≠ γ*, Δ(γ) > 0 (unique zero)
    (h_delta_pos : ∀ γ : ℝ, 0 < γ → γ ≠ γstar →
                   0 < Delta3 t0 c D0 t3 d3 γ)
    -- T(γ*) = T* (the minimum trace)
    (h_T_min : ∀ γ : ℝ, 0 < γ →
               T3 t0 c γstar ≤ T3 t0 c γ ∨
               Real.sqrt (Delta3 t0 c D0 t3 d3 γ) ≥
               T3 t0 c γstar - T3 t0 c γ)
    -- Any feasible γ
    (γ : ℝ) (hγ : 0 < γ) :
    -- Conclusion: ρ(γ*) ≤ ρ(γ)
    rho3 (T3 t0 c γstar) (Delta3 t0 c D0 t3 d3 γstar) ≤
    rho3 (T3 t0 c γ) (Delta3 t0 c D0 t3 d3 γ) ∧
    (γ ≠ γstar →
     rho3 (T3 t0 c γstar) (Delta3 t0 c D0 t3 d3 γstar) <
     rho3 (T3 t0 c γ) (Delta3 t0 c D0 t3 d3 γ)) := by
       -- By combining the results from h_T_min, we can conclude the proof for the first part of the conjunction.
       have h_rho3_ge : rho3 (T3 t0 c γstar) (Delta3 t0 c D0 t3 d3 γstar) ≤ rho3 (T3 t0 c γ) (Delta3 t0 c D0 t3 d3 γ) := by
         -- By definition of $rho3$, we know that $rho3 (T3 t0 c γstar) (Delta3 t0 c D0 t3 d3 γstar) = T3 t0 c γstar / 2$.
         simp [rho3, h_delta_zero];
         cases h_T_min γ hγ <;> linarith [ Real.sqrt_nonneg ( Delta3 t0 c D0 t3 d3 γ ) ];
       refine ⟨ h_rho3_ge, fun hne => lt_of_le_of_ne h_rho3_ge ?_ ⟩ ; intro h ; simp_all +decide [ rho3 ] ;
       -- By simplifying $h$, we get $T3 t0 c lam⁻¹ = T3 t0 c γ + \sqrt{Delta3 t0 c D0 t3 d3 γ}$.
       have h_simplified : T3 t0 c lam⁻¹ = T3 t0 c γ + Real.sqrt (Delta3 t0 c D0 t3 d3 γ) := by
         linarith;
       -- By definition of $T3$, we know that $T3 t0 c lam⁻¹ = t0 - lam⁻¹ * c$ and $T3 t0 c γ = t0 - γ * c$.
       have h_T3_def : t0 - lam⁻¹ * c = t0 - γ * c + Real.sqrt (Delta3 t0 c D0 t3 d3 γ) := by
         exact h_simplified ▸ rfl;
       -- By definition of $Delta3$, we know that $Delta3 t0 c D0 t3 d3 γ = (c^2 - 4*D0*d3) * (γ - lam⁻¹)^2$.
       have h_Delta3_def : Delta3 t0 c D0 t3 d3 γ = (c^2 - 4*D0*d3) * (γ - lam⁻¹)^2 := by
         -- By definition of $Delta3$, we know that $Delta3 t0 c D0 t3 d3 γ = (c^2 - 4*D0*d3)*(γ - lam⁻¹)^2$.
         apply delta3_eq_sq_of_zero t0 c D0 t3 d3 lam⁻¹ (by positivity) h_delta_zero (fun γ hγ => h_delta_nonneg γ hγ) γ
       generalize_proofs at *; (
       -- By simplifying $h_simplified_T3$, we get $c^2 * (γ - lam⁻¹)^2 = (c^2 - 4*D0*d3) * (γ - lam⁻¹)^2$.
       have h_simplified_T3_sq : c^2 * (γ - lam⁻¹)^2 = (c^2 - 4*D0*d3) * (γ - lam⁻¹)^2 := by
         grind
       generalize_proofs at *; (
       exact absurd h_simplified_T3_sq ( by nlinarith only [ show 0 < c ^ 2 by positivity, show 0 < 4 * D0 * d3 by positivity, show ( γ - lam⁻¹ ) ^ 2 > 0 by exact sq_pos_of_ne_zero ( sub_ne_zero_of_ne hne ) ] ) ;))

theorem conj_e_minimum_value
    (t0 c D0 t3 d3 lam : ℝ)
    (ht0 : 0 < t0) (hc : 0 < c) (hD0 : 0 < D0)
    (ht3 : 0 < t3) (hd3 : 0 < d3) (hlam : 0 < lam)
    (h_delta_zero : Delta3 t0 c D0 t3 d3 (1/lam) = 0)
    (h_delta_nonneg : ∀ γ : ℝ, 0 < γ → 0 ≤ Delta3 t0 c D0 t3 d3 γ) :
    -- The minimum value of ρ is T(γ*)/2
    rho3 (T3 t0 c (1/lam)) (Delta3 t0 c D0 t3 d3 (1/lam)) =
    T3 t0 c (1/lam) / 2 ∧
    -- And it equals (t0 - c/lam) / 2
    T3 t0 c (1/lam) / 2 = (t0 - c / lam) / 2 := by
  constructor
  · exact (rho3_eq_half_T_iff _ _
      (h_delta_nonneg (1/lam) (by positivity))).mpr h_delta_zero
  · unfold T3; ring