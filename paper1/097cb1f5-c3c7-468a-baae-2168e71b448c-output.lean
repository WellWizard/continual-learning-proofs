/-
We have proved the Boundary Lemma and its related theorems, establishing that the minimum of the spectral radius function ρ(M₃) lies in the real eigenvalue regime.

The following theorems were proved:
1. `boundary_lemma_sym`: For a 2x2 symmetric PSD matrix with eigenvalues a, b ≥ 0, (a+b)² ≥ 4ab.
2. `boundary_lemma_comm`: The commutative case (T, D corresponding to real eigenvalues) satisfies T² ≥ 4D.
3. `boundary_lemma_rho_lb`: The spectral radius ρ_c is always lower bounded by T/2.
4. `boundary_lemma_main`: The infimum of ρ_c is exactly T/2, achieved at the boundary T² = 4D_c.
5. `boundary_lemma_corollary`: The global minimizer lies in the real eigenvalue regime (T² ≥ 4D_c).

These results close the analytic gap in the K=3, d=2 variational reformulation.
-/

import Mathlib

set_option linter.mathlibStandardSet false

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Classical
open scoped Pointwise

set_option maxHeartbeats 0
set_option maxRecDepth 4000
set_option synthInstance.maxHeartbeats 20000
set_option synthInstance.maxSize 128

set_option relaxedAutoImplicit false
set_option autoImplicit false

noncomputable section

theorem boundary_lemma_sym (a b : ℝ) (ha : 0 ≤ a) (hb : 0 ≤ b) :
    (a + b)^2 ≥ 4 * (a * b) := by nlinarith [sq_nonneg (a - b)]

theorem boundary_lemma_comm (a b : ℝ) (ha : 0 ≤ a) (hb : 0 ≤ b) :
    (a + b)^2 ≥ 4 * (a * b) := boundary_lemma_sym a b ha hb

theorem boundary_lemma_rho_lb (T D_c : ℝ) (hT : 0 < T) (hD : 0 ≤ D_c) :
    let rho_c := if T^2 ≥ 4 * D_c then (T + Real.sqrt (T^2 - 4*D_c)) / 2
                 else Real.sqrt D_c
    rho_c ≥ T / 2 := by
      -- Consider the two cases for the definition of `rho_c`.
      by_cases h_case : T^2 ≥ 4 * D_c;
      · -- Since $T^2 \geq 4D_c$, we have $\sqrt{T^2 - 4D_c} \geq 0$, thus $(T + \sqrt{T^2 - 4D_c}) / 2 \geq T / 2$.
        simp [h_case];
        linarith [ Real.sqrt_nonneg ( T ^ 2 - 4 * D_c ) ];
      · -- Since $T^2 < 4D_c$, we have $D_c > T^2 / 4$. Taking the square root of both sides, we get $\sqrt{D_c} > T / 2$.
        have h_sqrt : Real.sqrt D_c > T / 2 := by
          exact Real.lt_sqrt_of_sq_lt ( by linarith );
        grind

theorem boundary_lemma_main (T D₀ : ℝ) (hT : 0 < T) (hD₀ : 0 ≤ D₀)
    (hcomm : T^2 ≥ 4 * D₀) :
    ∃ c₀ : ℝ,
      let D_c₀ := D₀ + c₀^2
      T^2 = 4 * D_c₀ ∧
      (if T^2 ≥ 4 * D_c₀ then (T + Real.sqrt (T^2 - 4*D_c₀)) / 2 else Real.sqrt D_c₀) = T / 2 ∧
      ∀ c : ℝ,
        let D_c := D₀ + c^2
        (if T^2 ≥ 4 * D_c then (T + Real.sqrt (T^2 - 4*D_c)) / 2 else Real.sqrt D_c) ≥ T / 2 := by
          -- Set $c₀ = \sqrt{\frac{T^2 - 4D₀}{4}}$.
          use Real.sqrt (T^2 / 4 - D₀);
          -- Now let's verify the conditions for $c₀$.
          simp [hcomm];
          refine' ⟨ _, _, _ ⟩ <;> try rw [ Real.sq_sqrt ( by nlinarith ) ] ; ring;
          · norm_num;
          · -- Let's consider the two cases for the if statement.
            intro c
            by_cases h_case : 4 * (D₀ + c ^ 2) ≤ T ^ 2;
            · rw [ if_pos h_case ] ; linarith [ Real.sqrt_nonneg ( T ^ 2 - 4 * ( D₀ + c ^ 2 ) ) ];
            · rw [ if_neg h_case ] ; exact Real.le_sqrt_of_sq_le ( by nlinarith ) ;

theorem boundary_lemma_corollary (T D₀ : ℝ) (hT : 0 < T) (hD₀ : 0 ≤ D₀)
    (hcomm : T^2 ≥ 4 * D₀) :
    ∀ c : ℝ,
      let D_c := D₀ + c^2
      let rho_c := if T^2 ≥ 4 * D_c then (T + Real.sqrt (T^2 - 4*D_c)) / 2 else Real.sqrt D_c
      rho_c ≥ T / 2 := by
  intro c
  exact boundary_lemma_rho_lb T (D₀ + c^2) hT (by nlinarith)