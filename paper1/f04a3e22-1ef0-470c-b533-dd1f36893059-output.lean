    ((1 : Matrix n n R) - gi • Si) * (1 - gj • Sj) -
    (1 - gj • Sj) * (1 - gi • Si) =
    (gi * gj) • (Si * Sj - Sj * Si) := by
      ext i j; simp +decide [ mul_sub, sub_mul, Matrix.mul_apply, smul_neg, smul_assoc ] ; ring;

/-
