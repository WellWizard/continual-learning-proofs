    g1 * g2 * trace (A4 * A3 * (S2 * S1 - S1 * S2)) := by
      simp +decide [ Matrix.trace_mul_comm ( 1 - g4 • S4 - g3 • ( ( 1 - g4 • S4 ) * S3 ) ), mul_assoc, mul_sub, sub_mul ] ; ring

