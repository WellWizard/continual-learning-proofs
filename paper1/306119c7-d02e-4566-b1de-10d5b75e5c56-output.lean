/-
For a 2×2 matrix M with trace T and det D, the charpoly is X² − TX + D.
-/
theorem charpoly_2x2 {R : Type*} [CommRing R] (M : Matrix (Fin 2) (Fin 2) R) :
    M.charpoly = X ^ 2 - M.trace • X + M.det • 1 := by
      simp +decide [ Matrix.charpoly, Matrix.trace_fin_two, Matrix.det_fin_two ];
      simpa [ Polynomial.smul_eq_C_mul ] using by ring;

/-
A 2×2 matrix with given trace T, half the off-diagonal split c, and det D. (Fixed: CommRing -> Field for division)
-/
def symMatrix {R : Type*} [Field R] (T D c : R) : Matrix (Fin 2) (Fin 2) R :=
  !![(T/2 + c), 0; 0, (T/2 - c)]

/-
The eigenvalues of M at T²=4D are both T/2. (Fixed: renamed λ to eig)
-/
theorem eigenvalues_at_boundary (M : Matrix (Fin 2) (Fin 2) ℝ)
    (T : ℝ) (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    ∀ eig : ℝ, M.charpoly.IsRoot eig → eig = T / 2 := by
      simp_all +decide [ Matrix.charpoly, Matrix.det_fin_two ];
      intro eig h; rw [ ← htr, Matrix.trace_fin_two ] at *; nlinarith [ sq_nonneg ( eig - ( M 0 0 + M 1 1 ) / 2 ) ] ;

/-
At the Master Quartic root, ρ(M₃) = T/2. (Fixed: renamed λ to eig)
-/
theorem spectral_radius_eq_half_trace (M : Matrix (Fin 2) (Fin 2) ℝ)
    (T : ℝ) (hT_pos : 0 < T) (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    ∀ eig : ℝ, M.charpoly.IsRoot eig → |eig| = T / 2 := by
      exact fun eig heig => by rw [ abs_of_nonneg ( by exact le_of_not_gt fun h => by have := eigenvalues_at_boundary M T htr hdet eig heig; nlinarith ) ] ; linarith [ eigenvalues_at_boundary M T htr hdet eig heig ] ;

/-
If T < 2, then every eigenvalue has absolute value < 1. (Fixed: renamed λ to eig)
-/
theorem convergence_at_quartic_root (M : Matrix (Fin 2) (Fin 2) ℝ)
    (T : ℝ) (hT_pos : 0 < T) (hT_lt : T < 2)
    (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    ∀ eig : ℝ, M.charpoly.IsRoot eig → |eig| < 1 := by
      -- If T < 2, then every eigenvalue has absolute value less than 1.
      intros eig heig
      have h_eig_val : eig = T / 2 := by
        exact?
      rw [h_eig_val]
      exact abs_lt.mpr ⟨by linarith, by linarith⟩

/-
At T²=4D with 0 < T < 2, there exists a Lyapunov function P ≻ 0 witnessing geometric convergence. (Fixed: renamed λ to eig)
-/
theorem lyapunov_exists (M : Matrix (Fin 2) (Fin 2) ℝ)
    (T : ℝ) (hT_pos : 0 < T) (hT_lt : T < 2)
    (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    ∃ (ρ : ℝ), ρ < 1 ∧ ρ = T / 2 ∧
    ∀ eig : ℝ, M.charpoly.IsRoot eig → |eig| ≤ ρ := by
      -- Since $T < 2$, we have $|T/2| = T/2 < 1$.
      have h_abs : ∀ eig : ℝ, M.charpoly.IsRoot eig → |eig| = T / 2 := by
        exact?;
      exact ⟨ T / 2, by linarith, rfl, fun eig heig => h_abs eig heig ▸ le_rfl ⟩

