/-
Algebraic identity for the characteristic polynomial at the boundary, assuming 2 is invertible.
-/
theorem charpoly_at_boundary_aux {R : Type*} [Field R] [Invertible (2 : R)] (T : R) :
    X ^ 2 - C T * X + C (T ^ 2 / 4) = (X - C (T / 2)) ^ 2 := by
      -- To prove the factorization, we can multiply both sides of the equation by $(s - T/2)^2 + (T^2 / 4)$ and show that both sides are equal.
      field_simp
      ring;
      ext; norm_num; ring;
      simp +decide [ sq, mul_assoc, Polynomial.coeff_C, Polynomial.coeff_X ] ; ring;
      norm_num [ sq ];
      rw [ show ( 4 : R ) = 2 * 2 by norm_num, mul_inv ]

/-
At T²=4D, the charpoly of M is (X − T/2)².
-/
theorem charpoly_at_boundary {R : Type*} [Field R] [Invertible (2 : R)] (M : Matrix (Fin 2) (Fin 2) R)
    (T : R) (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    M.charpoly = (X - C (T / 2)) ^ 2 := by
      -- By definition of the characteristic polynomial, we have M.charpoly = X^2 - trace(M) * X + det(M).
      have h_char_def : M.charpoly = Polynomial.X^2 - Polynomial.C (M.trace) * Polynomial.X + Polynomial.C (M.det) := by
        exact?;
      subst_vars;
      convert charpoly_at_boundary_aux ( M.trace ) using 1 ; ring_nf at * ; aesop ( simp_config := { decide := true } ) ;

/-
At T²=4D (the phase boundary), the matrix M satisfies (M - (T/2)·I)² = 0.
-/
theorem jordan_structure_at_boundary {R : Type*} [Field R] [Invertible (2 : R)] (M : Matrix (Fin 2) (Fin 2) R)
    (hT2D : M.det = M.trace ^ 2 / 4) :
    (M - (M.trace / 2) • (1 : Matrix (Fin 2) (Fin 2) R)) ^ 2 = 0 := by
      have h_charpoly_boundary : M.charpoly = (Polynomial.X - Polynomial.C (M.trace / 2))^2 := by
        convert charpoly_at_boundary M ( M.trace ) ( by simp +decide ) hT2D using 1;
      rw [ ← Matrix.aeval_self_charpoly, h_charpoly_boundary ];
      simp +decide [ sq, Matrix.smul_eq_diagonal_mul ];
      rfl

/-
Specialisation: the K=3 cycle operator at the quartic root.
-/
theorem jordan_block_at_quartic_root {R : Type*} [Field R] [Invertible (2 : R)] (M : Matrix (Fin 2) (Fin 2) R)
    (T : R) (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    (M - (T / 2) • (1 : Matrix (Fin 2) (Fin 2) R)) ^ 2 = 0 := by
  subst htr
  apply jordan_structure_at_boundary
  exact hdet

/-
Complete K=3 non-commutative closure.
-/
theorem K3_noncomm_closure (M : Matrix (Fin 2) (Fin 2) ℝ)
    (T : ℝ) (hT_pos : 0 < T) (hT_lt : T < 2)
    (htr : M.trace = T) (hdet : M.det = T ^ 2 / 4) :
    (M - (T / 2) • (1 : Matrix (Fin 2) (Fin 2) ℝ)) ^ 2 = 0 ∧
    M.charpoly = (X - C (T / 2)) ^ 2 ∧
    (∀ eig : ℝ, M.charpoly.IsRoot eig → |eig| = T / 2) ∧
    (∀ eig : ℝ, M.charpoly.IsRoot eig → |eig| < 1) := by
  haveI : Invertible (2 : ℝ) := invertibleOfNonzero (by norm_num)
  exact ⟨jordan_block_at_quartic_root M T htr hdet,
         charpoly_at_boundary M T htr hdet,
         spectral_radius_eq_half_trace M T hT_pos htr hdet,
         convergence_at_quartic_root M T hT_pos hT_lt htr hdet⟩