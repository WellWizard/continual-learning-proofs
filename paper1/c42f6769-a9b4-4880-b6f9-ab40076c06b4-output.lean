  simp [hκ]

/-
CONJECTURE E — K=3 INSTANCE: The optimal third stepsize is γ₃* = 1 / ⟨Σ₃ v*, v*⟩.
-/
theorem conjE_k3_instance
    (ρ₂_star eigval : ℝ)
    (hρ₂ : 0 < ρ₂_star) (hρ₂_lt1 : ρ₂_star < 1)
    (h_eigval : 0 < eigval) :
    let γ₃_star := 1 / eigval
    0 < γ₃_star ∧
    (1 : ℝ) - γ₃_star * eigval = 0 ∧
    γ₃_star = 2 / (eigval + eigval) ∧
    |1 - γ₃_star * eigval| = 0 ∧
    ∀ γ > 0, (1 : ℝ) - γ * eigval = 0 → γ = γ₃_star := by
      exact ⟨ one_div_pos.mpr h_eigval, by rw [ div_mul_cancel₀ _ h_eigval.ne' ] ; linarith, by ring, by rw [ div_mul_cancel₀ _ h_eigval.ne' ] ; norm_num, fun γ hγ hγ' => by rw [ eq_div_iff ] <;> nlinarith ⟩

