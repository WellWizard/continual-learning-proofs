/-
T(γ₃) = tr(M₃) is linear in γ₃.
-/
theorem conjE_trace_linear (T₂ c₃ γ₃ : ℝ) :
    T₂ - γ₃ * c₃ = T₂ + γ₃ * (-c₃) := by ring

/-
Trace reduction coefficient: c₃ = tr(Σ₃M₂*) is the sensitivity of T to γ₃.
-/
theorem conjE_trace_reduction (T₂ c₃ γ₃ γ₃' : ℝ) :
    (T₂ - γ₃ * c₃) - (T₂ - γ₃' * c₃) = (γ₃' - γ₃) * c₃ := by ring

