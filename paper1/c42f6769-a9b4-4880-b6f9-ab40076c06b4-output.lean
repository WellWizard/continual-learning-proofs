/-
Rayleigh quotient annihilation: ⟨(I - γ·Σ)v, v⟩ = 0 iff γ = 1/⟨Σv,v⟩.
-/
theorem rayleigh_quotient_annihilation
    (γ eigval : ℝ) (h_eigval : 0 < eigval) :
    (1 : ℝ) - γ * eigval = 0 ↔ γ = 1 / eigval := by
      constructor <;> intro h <;> rw [ eq_div_iff ] at * <;> nlinarith

/-
The annihilation stepsize is strictly positive when λ > 0.
-/
theorem conjE_stepsize_positive (eigval : ℝ) (h_eigval : 0 < eigval) : 0 < 1 / eigval := by
