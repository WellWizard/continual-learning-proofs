      1 - γstar * t + γstar^2 * d ≤ 1 - γ' * t + γ'^2 * d := by
        -- Substitute γstar into the quadratic expression and simplify.
        field_simp [mul_comm, mul_assoc, mul_left_comm];
        -- By completing the square, we can show that the quadratic expression is non-negative.
