        have h2_bound : 1 - γ2 * t2 + γ2^2 * d2 ≥ 1 - t2 / (2 * d2) * t2 + (t2 / (2 * d2))^2 * d2 := by
          field_simp [hd2] at *;
          nlinarith [ sq_nonneg ( t2 - 2 * d2 * γ2 ) ];
