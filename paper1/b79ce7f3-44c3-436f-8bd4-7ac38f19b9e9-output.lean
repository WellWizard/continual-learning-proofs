      0 < γ1 → 0 < γ2 →
      let D := (1 - γ1 * t1 + γ1^2 * d1) * (1 - γ2 * t2 + γ2^2 * d2)
      (1 - γ1 * t1 + γ1^2 * d1) ≤ 0 → (1 - γ2 * t2 + γ2^2 * d2) ≤ 0 →
      D ≤ D_star := by
        -- By definition of $Dstar$, we know that $Dstar = (1 - γ1star * t1 + γ1star^2 * d1) * (1 - γ2star * t2 + γ2star^2 * d2)$.
