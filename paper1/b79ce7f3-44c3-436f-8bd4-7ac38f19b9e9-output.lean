          -- Since $d > 0$, the product $d * (γ' * d - t / 2) ^ 2$ is non-negative because the square of any real number is non-negative.
          apply mul_nonneg hd.le; apply sq_nonneg;
        -- By combining terms, we can factor out $d$ and simplify the expression.
        nlinarith [mul_pos hd ht]

