        have h_prod_decreasing : ∀ {a b c d : ℝ}, a ≤ b → c ≤ d → a ≤ 0 → b ≤ 0 → c ≤ 0 → d ≤ 0 → a * c ≥ b * d := by
          intros a b c d hab hcd ha hb hc hd; nlinarith;
        exact h_prod_decreasing ( by linarith ) ( by linarith ) ( by linarith ) ( by linarith ) ( by linarith ) ( by linarith )

