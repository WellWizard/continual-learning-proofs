/-
If S is a symmetric matrix, then the update matrix I - gS is also symmetric.
-/
open Matrix

lemma update_op_sym {n : Type*} [Fintype n] [DecidableEq n] {R : Type*} [CommRing R] (g : R) (S : Matrix n n R) (hS : Sᵀ = S) :
    ((1 : Matrix n n R) - g • S)ᵀ = (1 : Matrix n n R) - g • S := by
  simp [transpose_sub, transpose_one, transpose_smul, hS]

/-
The trace of the product of four symmetric update matrices is equal to the trace of the product of the matrices in reverse order.
-/
open Matrix

theorem cubic_collapse_K4
    {n : Type*} [Fintype n] [DecidableEq n] {R : Type*} [CommRing R]
    (g1 g2 g3 g4 : R) (S1 S2 S3 S4 : Matrix n n R)
    (h1 : S1ᵀ = S1) (h2 : S2ᵀ = S2) (h3 : S3ᵀ = S3) (h4 : S4ᵀ = S4) :
    let A1 := (1 : Matrix n n R) - g1 • S1
    let A2 := (1 : Matrix n n R) - g2 • S2
    let A3 := (1 : Matrix n n R) - g3 • S3
    let A4 := (1 : Matrix n n R) - g4 • S4
    trace (A4 * A3 * A2 * A1) = trace (A1 * A2 * A3 * A4) := by
  simp only []
  -- Step 1: each Aᵢ is symmetric
  set A1 := (1 : Matrix n n R) - g1 • S1
  set A2 := (1 : Matrix n n R) - g2 • S2
  set A3 := (1 : Matrix n n R) - g3 • S3
  set A4 := (1 : Matrix n n R) - g4 • S4
  have hA1 : A1ᵀ = A1 := update_op_sym g1 S1 h1
  have hA2 : A2ᵀ = A2 := update_op_sym g2 S2 h2
  have hA3 : A3ᵀ = A3 := update_op_sym g3 S3 h3
  have hA4 : A4ᵀ = A4 := update_op_sym g4 S4 h4
  -- Step 2: (A₄A₃A₂A₁)ᵀ = A₁A₂A₃A₄
  have hrev : (A4 * A3 * A2 * A1)ᵀ = A1 * A2 * A3 * A4 := by
    simp [transpose_mul, hA1, hA2, hA3, hA4, mul_assoc]
  -- Step 3: tr(M) = tr(Mᵀ)
  nth_rw 1 [← hrev]
  exact trace_transpose _

/-
The difference between the trace of the product of four symmetric update matrices and the trace of the product of the matrices in reverse order is zero.
-/
open Matrix

theorem cubic_terms_vanish_K4
    {n : Type*} [Fintype n] [DecidableEq n] {R : Type*} [CommRing R]
    (g1 g2 g3 g4 : R) (S1 S2 S3 S4 : Matrix n n R)
    (h1 : S1ᵀ = S1) (h2 : S2ᵀ = S2) (h3 : S3ᵀ = S3) (h4 : S4ᵀ = S4) :
    let A1 := (1 : Matrix n n R) - g1 • S1
    let A2 := (1 : Matrix n n R) - g2 • S2
    let A3 := (1 : Matrix n n R) - g3 • S3
    let A4 := (1 : Matrix n n R) - g4 • S4
    trace (A4 * A3 * A2 * A1) - trace (A1 * A2 * A3 * A4) = 0 := by
      convert sub_eq_zero_of_eq ( cubic_collapse_K4 g1 g2 g3 g4 S1 S2 S3 S4 h1 h2 h3 h4 ) using 1

