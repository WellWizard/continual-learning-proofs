open Matrix

def cubic_coeff (S1 S2 S3 : Matrix (Fin 2) (Fin 2) ℝ) : ℝ :=
  (eps S1 S2 * S3.trace + eps S1 S3 * S2.trace + eps S2 S3 * S1.trace) / 2

