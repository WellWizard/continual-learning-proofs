open Matrix

def J2 : Matrix (Fin 2) (Fin 2) ℝ := !![0, 1; -1, 0]

/-
Definition of the scalar epsilon derived from the commutator of two matrices.
-/
open Matrix

def eps (A B : Matrix (Fin 2) (Fin 2) ℝ) : ℝ := (A * B - B * A) 0 1

/-
The commutator of two 2x2 symmetric matrices is proportional to J2.
-/
open Matrix

theorem commutator_structure
  (S1 S2 : Matrix (Fin 2) (Fin 2) ℝ)
  (hS1 : S1.IsSymm) (hS2 : S2.IsSymm) :
  S1 * S2 - S2 * S1 = (eps S1 S2) • J2 := by
  unfold eps J2;
  have hS : S1 1 0 = S1 0 1 ∧ S2 1 0 = S2 0 1 := by
    exact ⟨ by simpa using congr_fun ( congr_fun hS1 0 ) 1, by simpa using congr_fun ( congr_fun hS2 0 ) 1 ⟩;
  ext i j ; fin_cases i <;> fin_cases j <;> norm_num [ hS, Matrix.mul_apply ] <;> ring!;

/-
The product of three matrices A3 A2 A1 expands to a specific polynomial in g and S.
