open Matrix

theorem commutator_of_A
  (g1 g2 : ℝ)
  (S1 S2 : Matrix (Fin 2) (Fin 2) ℝ)
  (hS1 : S1.IsSymm) (hS2 : S2.IsSymm)
  (A1 : Matrix (Fin 2) (Fin 2) ℝ) (hA1 : A1 = 1 - g1 • S1)
  (A2 : Matrix (Fin 2) (Fin 2) ℝ) (hA2 : A2 = 1 - g2 • S2) :
