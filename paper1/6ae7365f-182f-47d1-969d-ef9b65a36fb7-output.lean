open Matrix

theorem expansion_identity
  (g1 g2 g3 : ℝ)
  (S1 S2 S3 : Matrix (Fin 2) (Fin 2) ℝ)
  (A1 : Matrix (Fin 2) (Fin 2) ℝ) (hA1 : A1 = 1 - g1 • S1)
  (A2 : Matrix (Fin 2) (Fin 2) ℝ) (hA2 : A2 = 1 - g2 • S2)
  (A3 : Matrix (Fin 2) (Fin 2) ℝ) (hA3 : A3 = 1 - g3 • S3) :
