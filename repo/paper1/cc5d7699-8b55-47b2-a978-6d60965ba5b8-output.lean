lemma nf_matrix_det (P Q : Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ) :
    (nf_matrix P Q γ).det =
    P.det ^ 2 * Q.det * γ ^ 2
    - 2 * P.trace * P.det * Q.det * γ
    + (P * Q + Q * P).det := by
      -- By expanding the determinant using the formula for the determinant of a 2x2 matrix, we can verify the equality. Let's expand the determinant of the NF matrix.
      simp [nf_matrix] at *;
      -- By expanding the determinant using the formula for the determinant of a 2x2 matrix, we can verify the equality by direct computation. Let's expand the determinant of the NF matrix and simplify.
      simp [Matrix.mul_apply, Matrix.trace, Matrix.det_fin_two]
      ring

/-- The NF condition Aᵢ Σⱼ Aᵢ ≼ Σⱼ holds iff Mᵢⱼ ≽ 0 (for γᵢ > 0). -/
lemma nf_condition_iff_mij_psd (P Q : Matrix (Fin 2) (Fin 2) ℝ)
