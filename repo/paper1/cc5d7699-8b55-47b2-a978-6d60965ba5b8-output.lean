          norm_num [ Matrix.mulVec, dotProduct ];
          nlinarith [ sq_nonneg ( x 0 ), sq_nonneg ( x 1 ) ])⟩;
      simp_all +decide [ le_div_iff₀ ];
      constructor <;> intro <;> nlinarith [ mul_pos hlam hmu ] ;

