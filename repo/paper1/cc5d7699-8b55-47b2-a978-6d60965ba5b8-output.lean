lemma nf_condition_iff_mij_psd_proven (P Q : Matrix (Fin 2) (Fin 2) ℝ)
    (hP : P.IsSymm) (hQ : Q.IsSymm) (γ : ℝ) (hγ : 0 < γ) :
    (1 - γ • P) * Q * (1 - γ • P) ≤ Q  ↔  0 ≤ nf_matrix P Q γ := by
      -- Apply the lemma that states the equivalence between the NF condition and the positivity of the NF matrix.
      apply nf_condition_iff_mij_psd P Q hP hQ γ hγ

lemma nf_matrix_det_proven (P Q : Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ) :
    (nf_matrix P Q γ).det =
    P.det ^ 2 * Q.det * γ ^ 2
    - 2 * P.trace * P.det * Q.det * γ
    + (P * Q + Q * P).det := by
      -- Apply the determinant formula for the NF matrix.
      apply nf_matrix_det

/-- The trace condition gives: γᵢ ≤ 2·tr(Sᵢ Sⱼ) / tr(Sᵢ² Sⱼ).
    For j=i this gives: γᵢ ≤ 2·tr(Sᵢ²) / tr(Sᵢ³) = 2 / λ_max(Sᵢ)
    (the harmonic mean of eigenvalues squared / cubed). -/
lemma nf_trace_upper_bound_proven
    (P Q : Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ)
    (htr : 0 ≤ 2 * (P * Q).trace - γ * (P * P * Q).trace)
    (hden : 0 < (P * P * Q).trace) :
    γ ≤ 2 * (P * Q).trace / (P * P * Q).trace := by
  rw [le_div_iff₀ hden]
  linarith