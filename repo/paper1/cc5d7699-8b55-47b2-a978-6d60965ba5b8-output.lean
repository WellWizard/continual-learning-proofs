      -- Since $(P * P * Q).trace$ is positive, we can divide both sides of the inequality $2 * (P * Q).trace ≥ γ * (P * P * Q).trace$ by $(P * P * Q).trace$ without changing the direction of the inequality.
      have h_gamma_le : γ ≤ 2 * (P * Q).trace / (P * P * Q).trace := by
        have h_pos : 0 < (P * P * Q).trace := hden
        exact le_div_iff₀ h_pos |>.2 (by linarith);
      -- Apply the hypothesis `h_gamma_le` directly to conclude the proof.
      exact h_gamma_le

