    Verified: tr(SᵢSⱼSᵢ) = tr(Sᵢ² Sⱼ) by cyclic property. -/
lemma nf_matrix_trace (P Q : Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ) :
    (nf_matrix P Q γ).trace =
    2 * (P * Q).trace - γ * (P * P * Q).trace := by
      -- By definition of $nf_matrix$, we have $nf_matrix P Q γ = P * Q + Q * P - γ • (P * Q * P)$.
      have h_nf_matrix : nf_matrix P Q γ = P * Q + Q * P - γ • (P * Q * P) := by
        -- By definition of nf_matrix, we have:
        simp [nf_matrix];
      -- By definition of matrix multiplication and the trace, we can expand the trace of each term.
      simp [h_nf_matrix, Matrix.trace_add, Matrix.trace_smul];
      norm_num [ Matrix.trace, Matrix.mul_apply ] ; ring

/-- det(Mᵢⱼ) = det(P)²·det(Q)·γ² − 2·tr(P)·det(P)·det(Q)·γ + det(PQ+QP)
