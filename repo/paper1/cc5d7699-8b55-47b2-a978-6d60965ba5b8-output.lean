/-- The NF matrix Mᵢⱼ(γ) = Sᵢ Sⱼ + Sⱼ Sᵢ − γ · Sᵢ Sⱼ Sᵢ -/
def nf_matrix (P Q : Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ) :
    Matrix (Fin 2) (Fin 2) ℝ :=
  P * Q + Q * P - γ • (P * Q * P)

/-- The NF matrix Mᵢⱼ is symmetric when Sᵢ and Sⱼ are symmetric. -/
lemma nf_matrix_isSymm (P Q : Matrix (Fin 2) (Fin 2) ℝ)
    (hP : P.IsSymm) (hQ : Q.IsSymm) (γ : ℝ) :
    (nf_matrix P Q γ).IsSymm := by
      -- The transpose of a matrix is linear and the transpose of a scalar multiple is the scalar multiple of the transpose.
      simp [Matrix.IsSymm, Matrix.transpose_add, Matrix.transpose_mul, Matrix.transpose_smul] at *;
      -- The transpose of a matrix is linear and the transpose of a scalar multiple is the scalar multiple of the transpose. Therefore, the transpose of M_PQ is equal to M_PQ.
      simp [nf_matrix, hP, hQ, Matrix.transpose_mul, Matrix.transpose_smul];
      -- By commutativity of addition, we can rearrange the terms on the left-hand side to match the right-hand side.
      simp [add_comm, mul_assoc]

/-- Expansion: Σⱼ − Aᵢ Σⱼ Aᵢ = γᵢ · Mᵢⱼ where Aᵢ = I − γᵢ Sᵢ -/
lemma nf_expansion (P Q : Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ) :
    Q - (1 - γ • P) * Q * (1 - γ • P) = γ • nf_matrix P Q γ := by
      -- Expand the left-hand side using the distributive property.
      simp [nf_matrix];
      -- Expanding the left-hand side:
      simp [mul_sub, sub_mul, mul_assoc, smul_sub, sub_smul];
      grind

