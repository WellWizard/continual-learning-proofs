/-- The non-forgetting set for K=3 tasks at d=2.
    γ = (γ₀, γ₁, γ₂), S = (S₀, S₁, S₂) : covariance matrices. -/
def NF3 (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) (γ : Fin 3 → ℝ) : Prop :=
  ∀ i j : Fin 3,
    (1 - γ i • S i) * S j * (1 - γ i • S i) ≤ S j

/-- **Main Theorem — NF(3) Semialgebraic Characterisation**:

    For 2×2 symmetric PD covariances S₀, S₁, S₂ and stepsizes γ₀, γ₁, γ₂ > 0,
    the non-forgetting condition NF(3) is equivalent to 18 polynomial inequalities:
    for each i,j ∈ {0,1,2}:

      (Tr)  2·tr(Sᵢ Sⱼ) − γᵢ·tr(Sᵢ² Sⱼ) ≥ 0
      (Det) det(Sᵢ)²·det(Sⱼ)·γᵢ² − 2·tr(Sᵢ)·det(Sᵢ)·det(Sⱼ)·γᵢ + det(Sᵢ Sⱼ + Sⱼ Sᵢ) ≥ 0 -/
theorem nf3_semialgebraic
    (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ)
    (hS : ∀ i, (S i).IsSymm)
    (γ : Fin 3 → ℝ)
    (hγ : ∀ i, 0 < γ i) :
    NF3 S γ  ↔
    ∀ i j : Fin 3,
      -- (Tr) trace condition
      0 ≤ 2 * (S i * S j).trace - γ i * (S i * S i * S j).trace  ∧
      -- (Det) determinant condition
      0 ≤ (S i).det ^ 2 * (S j).det * (γ i) ^ 2
          - 2 * (S i).trace * (S i).det * (S j).det * (γ i)
          + (S i * S j + S j * S i).det := by
  unfold NF3
  constructor
  · intro hnf i j
    have hmij := (nf_condition_iff_mij_psd (S i) (S j) (hS i) (hS j) (γ i) (hγ i)).mp (hnf i j)
    have hms := nf_matrix_isSymm (S i) (S j) (hS i) (hS j) (γ i)
    rw [psd_iff_tr_det_nonneg _ hms] at hmij
    constructor
    · rw [← nf_matrix_trace]; exact hmij.1
    · rw [← nf_matrix_det]; exact hmij.2
  · intro hpoly i j
    apply (nf_condition_iff_mij_psd (S i) (S j) (hS i) (hS j) (γ i) (hγ i)).mpr
    rw [psd_iff_tr_det_nonneg _ (nf_matrix_isSymm (S i) (S j) (hS i) (hS j) (γ i))]
    obtain ⟨htr, hdet⟩ := hpoly i j
    exact ⟨by rwa [nf_matrix_trace], by rwa [nf_matrix_det]⟩

