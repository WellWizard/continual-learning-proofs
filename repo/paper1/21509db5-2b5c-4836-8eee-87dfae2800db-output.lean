/-
Lemma: The greedy step size choice ensures that the maximum weighted product does not increase.
-/
lemma greedy_step_decrease {n : Type} [Fintype n] [DecidableEq n] [Nonempty n]
    (p : n → ℝ) (lam : n → ℝ) (hp : ∀ i, 0 ≤ p i) (hlam : ∀ i, 0 ≤ lam i) :
    let j_opt := Finset.argmax (fun j => p j * lam j) Finset.univ
    let g := match j_opt with | some j => 1 / lam j | none => 0
    let p' := fun i => p i * |1 - g * lam i|
    Finset.univ.sup' Finset.univ_nonempty p' ≤ Finset.univ.sup' Finset.univ_nonempty p := by
      -- Let's simplify the goal using the definition of `j_opt` and `g`.
      simp [Finset.argmax] at *;
      cases h : List.argmax ( fun j => p j * lam j ) Finset.univ.toList <;> simp_all +decide [ ne_of_gt ];
      rw [ List.argmax_eq_some_iff ] at h;
      by_cases h : lam ‹_› = 0 <;> simp_all +decide [ abs_of_nonneg, mul_nonneg, hp, hlam ];
      · exact?;
      · rename_i i hi;
        field_simp;
        -- Let $b$ be the index that maximizes $p_j$.
        obtain ⟨b, hb⟩ : ∃ b, ∀ j, p j ≤ p b := by
          simpa using Finset.exists_max_image Finset.univ p ( Finset.univ_nonempty );
        use b;
        intro j; rw [ abs_div ] ; rw [ abs_of_nonneg ( hlam i ) ] ; rw [ mul_div ] ; rw [ div_le_iff₀ ( lt_of_le_of_ne ( hlam i ) ( Ne.symm h ) ) ] ; cases abs_cases ( lam i - lam j ) <;> nlinarith [ hb j, hb i, hp j, hp i, hlam j, hlam i, hi.1 j, hi.1 i ] ;

/-
