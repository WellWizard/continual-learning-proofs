def check_ratio : List (ℚ × ℚ × ℚ) :=
  let S := test_S_rat
  let t := trace_sum_rat S
  let d := det_sum_rat S
  let c := pairwise_sum_rat S
  let k := system_skew_rat S
  [1, 2, 3].map fun i =>
