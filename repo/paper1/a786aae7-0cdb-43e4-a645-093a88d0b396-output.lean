        -- Since $|z_1| < 1$ and $|z_2| < 1$, we have $|z_1 z_2| < 1$.
        have h_prod : ‖z1 * z2‖ < 1 := by
          simpa using mul_lt_mul'' ( h z1 ( by linear_combination' hz.1 * z1 - hz.2 ) ) ( h z2 ( by linear_combination' hz.1 * z2 - hz.2 ) ) ( by positivity ) ( by positivity );
        aesop;
      · by_cases h_discriminant : T^2 - 4 * D ≥ 0;
        · have h_real_roots : ∀ z : ℝ, z^2 - T * z + D = 0 → |z| < 1 := by
            exact fun z hz => by simpa [ ← Complex.ofReal_inj ] using h z ( mod_cast hz ) ;
          have h1 := h_real_roots ( ( T + Real.sqrt ( T^2 - 4 * D ) ) / 2 ) ( by linarith [ Real.mul_self_sqrt h_discriminant ] ) ; have h2 := h_real_roots ( ( T - Real.sqrt ( T^2 - 4 * D ) ) / 2 ) ( by linarith [ Real.mul_self_sqrt h_discriminant ] ) ; rw [ abs_lt ] at * ; constructor <;> nlinarith [ Real.sqrt_nonneg ( T^2 - 4 * D ), Real.mul_self_sqrt h_discriminant ] ;
        · have := h ( ( T + Complex.I * Real.sqrt ( 4 * D - T ^ 2 ) ) / 2 ) ?_ <;> norm_num [ Complex.ext_iff, sq ] at *;
          · norm_num [ Complex.normSq, Complex.norm_def ] at this;
            rw [ Real.mul_self_sqrt ( by nlinarith ) ] at this ; rw [ div_lt_iff₀ ( by positivity ) ] at this ; rw [ Real.sqrt_lt' ] at this <;> cases abs_cases T <;> nlinarith [ Real.sqrt_nonneg ( 4 * D - T * T ), Real.mul_self_sqrt ( by nlinarith : 0 ≤ 4 * D - T * T ) ] ;
          · grind;
    · field_simp;
