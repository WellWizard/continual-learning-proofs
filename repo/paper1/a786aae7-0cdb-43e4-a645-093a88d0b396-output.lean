/-
Checking if the Master Quartic is equal to (T^2 - 4D) / γ^2.
-/
def check_hypothesis : List (ℚ × ℚ × ℚ) :=
  let S := test_S_rat
  let t := trace_sum_rat S
  let d := det_sum_rat S
  let c := pairwise_sum_rat S
  let k := system_skew_rat S
  [1, 2, 3].map fun i =>
    let γ : ℚ := mkRat i 10
    let mq := master_quartic_rat t d c k γ
    let M := cycle_operator_rat S γ
    let disc := M.trace ^ 2 - 4 * M.det
    let ratio := disc / (γ^2)
    (mq, ratio, mq - ratio)

#eval check_hypothesis

