        rw [ Real.sqrt_lt' ] <;> cases lt_or_gt_of_ne h_real <;> cases abs_cases D <;> cases abs_cases T <;> nlinarith [ sq_nonneg ( z.re - 1 ), sq_nonneg ( z.re + 1 ) ]

/-
For symmetric matrices, tr(S0 S1 S2) = tr(S2 S1 S0).
-/
lemma trace_S0S1S2_eq_trace_S2S1S0
  (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ)
  (h_symm : ∀ i, (S i).IsSymm) :
  (S 0 * S 1 * S 2).trace = (S 2 * S 1 * S 0).trace := by
    rw [ ← Matrix.trace_transpose ] ; simp +decide [ Matrix.mul_assoc, Matrix.transpose_mul, h_symm ] ;
    simp +decide only [h_symm _ |> Matrix.IsSymm.eq]

/-
Evaluating the Master Quartic and the discriminant for a test case to check for a relationship.
-/
def test_S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ :=
  ![ !![2, 0; 0, 1], !![1, 1; 1, 2], !![3, 0; 0, 1] ]

def test_vals : ℝ × ℝ :=
  let S := test_S
  let γ := 0.1
  let t := trace_sum S
  let d := det_sum S
  let c := pairwise_sum S
  let k := system_skew S
  let mq := master_quartic t d c k γ
  let disc := (cycle_operator S γ).trace ^ 2 - 4 * (cycle_operator S γ).det
  (mq, disc)

#eval test_vals

/-
Checking the values of the Master Quartic and the stability conditions for a test case.
-/
def check_vals : List (ℝ × ℝ × ℝ × ℝ) :=
  let S := test_S
  let t := trace_sum S
  let d := det_sum S
  let c := pairwise_sum S
  let k := system_skew S
  [0.1, 0.2, 0.5, 1.0].map fun γ =>
    let mq := master_quartic t d c k γ
    let M := cycle_operator S γ
    let stab1 := 1 + M.det - M.trace
    let stab2 := 1 - M.det
    let stab3 := 1 + M.det + M.trace
    (mq, stab1, stab2, stab3)

#eval check_vals

/-
Evaluating the Master Quartic and Discriminant on rational matrices to find the relationship.
-/
def master_quartic_rat (t d c k γ : ℚ) : ℚ :=
  (k^2 - 4*d^3)*γ^4 +
  (12*t*d^2 - 6*c*k)*γ^3 +
  (9*c^2 + 6*t*k - 12*t^2*d - 12*d^2)*γ^2 +
  (4*t^3 + 24*t*d - 18*t*c - 4*k)*γ +
  (12*c - 12*d - 3*t^2)

def cycle_operator_rat (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℚ) (γ : ℚ) : Matrix (Fin 2) (Fin 2) ℚ :=
  (1 - γ • S 2) * (1 - γ • S 1) * (1 - γ • S 0)

def trace_sum_rat (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℚ) : ℚ :=
  (S 0).trace + (S 1).trace + (S 2).trace

def det_sum_rat (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℚ) : ℚ :=
  (S 0).det + (S 1).det + (S 2).det

def pairwise_sum_rat (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℚ) : ℚ :=
  (S 0 * S 1).trace + (S 1 * S 2).trace + (S 2 * S 0).trace

def system_skew_rat (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℚ) : ℚ :=
  (S 0 * S 1 * S 2) 0 1 - (S 0 * S 1 * S 2) 1 0

def test_S_rat : Fin 3 → Matrix (Fin 2) (Fin 2) ℚ :=
  ![ !![2, 0; 0, 1], !![1, 1; 1, 2], !![3, 0; 0, 1] ]

def check_poly_relation : List (ℚ × ℚ) :=
  let S := test_S_rat
  let t := trace_sum_rat S
  let d := det_sum_rat S
  let c := pairwise_sum_rat S
  let k := system_skew_rat S
  [1, 2, 3, 4, 5].map fun i =>
    let γ : ℚ := i
    let mq := master_quartic_rat t d c k γ
    let M := cycle_operator_rat S γ
    let disc := M.trace ^ 2 - 4 * M.det
    (mq, disc)

#eval check_poly_relation

/-
Checking the stability boundaries against the Master Quartic.
-/
def check_stability_boundaries : List (ℚ × ℚ × ℚ × ℚ) :=
  let S := test_S_rat
  let t := trace_sum_rat S
  let d := det_sum_rat S
  let c := pairwise_sum_rat S
  let k := system_skew_rat S
  [1, 2, 3, 4, 5].map fun i =>
    let γ : ℚ := i
    let mq := master_quartic_rat t d c k γ
    let M := cycle_operator_rat S γ
    let b1 := 1 - M.det
    let b2 := 1 + M.det - M.trace
    let b3 := 1 + M.det + M.trace
    (mq, b1, b2, b3)

#eval check_stability_boundaries

