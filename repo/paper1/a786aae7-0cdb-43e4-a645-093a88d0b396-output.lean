/-
The Master Quartic Polynomial f(γ) for the K=3 Continual Learning Cycle.
-/
def master_quartic (t d c k γ : ℝ) : ℝ :=
  (k^2 - 4*d^3)*γ^4 +
  (12*t*d^2 - 6*c*k)*γ^3 +
  (9*c^2 + 6*t*k - 12*t^2*d - 12*d^2)*γ^2 +
  (4*t^3 + 24*t*d - 18*t*c - 4*k)*γ +
  (12*c - 12*d - 3*t^2)

/-
The cycle operator for K=3 tasks, defined as the product of the update matrices (I - γ S_i).
-/
def cycle_operator (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) (γ : ℝ) : Matrix (Fin 2) (Fin 2) ℝ :=
  (1 - γ • S 2) * (1 - γ • S 1) * (1 - γ • S 0)

/-
Definitions of the system constants: Trace sum, Determinant sum, Pairwise trace sum, and Cubic Skew (which is 0 for symmetric matrices).
-/
def trace_sum (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) : ℝ :=
  (S 0).trace + (S 1).trace + (S 2).trace

def det_sum (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) : ℝ :=
  (S 0).det + (S 1).det + (S 2).det

def pairwise_sum (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) : ℝ :=
  (S 0 * S 1).trace + (S 1 * S 2).trace + (S 2 * S 0).trace

def cubic_skew (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) : ℝ := 0

/-
The cubic skew parameter, defined as the off-diagonal difference of the product S0 S1 S2.
-/
def system_skew (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ) : ℝ :=
  (S 0 * S 1 * S 2) 0 1 - (S 0 * S 1 * S 2) 1 0

/-
The determinant of the cycle operator is the product of the determinants of the individual update matrices.
-/
lemma cycle_det_expansion
  (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ)
  (γ : ℝ) :
  (cycle_operator S γ).det = (1 - γ * (S 0).trace + γ^2 * (S 0).det) *
                             (1 - γ * (S 1).trace + γ^2 * (S 1).det) *
                             (1 - γ * (S 2).trace + γ^2 * (S 2).det) := by
                               unfold cycle_operator;
                               norm_num [ Matrix.det_fin_two, Matrix.trace_fin_two ] ; ring;

/-
The trace of the cycle operator expanded in terms of γ, with the correct order of multiplication for the cubic term.
-/
lemma cycle_trace_expansion
  (S : Fin 3 → Matrix (Fin 2) (Fin 2) ℝ)
  (γ : ℝ) :
  (cycle_operator S γ).trace = 2 - γ * (S 0).trace - γ * (S 1).trace - γ * (S 2).trace +
                               γ^2 * ((S 0 * S 1).trace + (S 1 * S 2).trace + (S 2 * S 0).trace) -
                               γ^3 * ((S 2 * S 1 * S 0).trace) := by
                                 unfold cycle_operator; norm_num [ Matrix.trace, Matrix.mul_apply ] ; ring;

/-
The Jury stability criterion for a 2x2 matrix with trace T and determinant D: all eigenvalues are in the unit disk iff |D| < 1 and |T| < 1 + D.
-/
