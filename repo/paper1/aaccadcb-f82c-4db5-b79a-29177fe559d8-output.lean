theorem e2_determined_by_trace_sq (Оів‚Ѓ Оів‚‚ Оів‚ѓ : R)
    (Sв‚Ѓ Sв‚‚ Sв‚ѓ : Matrix (Fin n) (Fin n) R) :
    let M := M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ
    trace M ^ 2 - trace (M * M) =
    (trace ((1 - Оів‚ѓ вЂў Sв‚ѓ) * (1 - Оів‚‚ вЂў Sв‚‚) * (1 - Оів‚Ѓ вЂў Sв‚Ѓ))) ^ 2 -
    trace (((1 - Оів‚ѓ вЂў Sв‚ѓ) * (1 - Оів‚‚ вЂў Sв‚‚) * (1 - Оів‚Ѓ вЂў Sв‚Ѓ)) *
           ((1 - Оів‚ѓ вЂў Sв‚ѓ) * (1 - Оів‚‚ вЂў Sв‚‚) * (1 - Оів‚Ѓ вЂў Sв‚Ѓ))) := by
  simp [M3]

-- ============================================================
-- SECTION 6: THEOREM C вЂ” the interleaved quartic
-- ============================================================

/-- THEOREM C: Decomposition of the interleaved quartic.
    tr(ABAB) = tr(AВІBВІ) + tr(AВ·[B,A]В·B)
    where [B,A] = BA - AB is the commutator.

    This makes precise: pбµўв±ј = tr(SбµўSв±јSбµўSв±ј) decomposes into
    a "commutative part" tr(SбµўВІSв±јВІ) and a "commutator correction" tr(Sбµў[Sв±ј,Sбµў]Sв±ј).
    The correction VANISHES iff [Sбµў,Sв±ј] = 0. -/
theorem interleaved_quartic_decomp (A B : Matrix (Fin n) (Fin n) R) :
    trace (A * B * A * B) =
    trace (A * A * B * B) + trace (A * (B * A - A * B) * B) := by
      -- By expanding the right-hand side, we can see that the terms cancel out, leaving zero.
      simp [mul_sub, sub_mul, mul_assoc]

/-- THEOREM C': When matrices commute, the interleaved quartic reduces.
    If [A,B] = 0 then tr(ABAB) = tr(AВІBВІ). -/
theorem interleaved_quartic_commutes (A B : Matrix (Fin n) (Fin n) R)
    (h : A * B = B * A) :
    trace (A * B * A * B) = trace (A * A * (B * B)) := by
      grind

/-- The interleaved quartic pбµўв±ј is the key non-commutative invariant
    at degree 4. It measures "how non-commutative" Sбµў and Sв±ј are. -/
def interleaved_quartic (Sв‚Ѓ Sв‚‚ : Matrix (Fin n) (Fin n) R) : R :=
  trace (Sв‚Ѓ * Sв‚‚ * Sв‚Ѓ * Sв‚‚)

/-- The commutative correction: pбµўв±ј - tr(SбµўВІSв±јВІ) = tr(Sбµў[Sв±ј,Sбµў]Sв±ј) -/
theorem interleaved_quartic_correction (Sв‚Ѓ Sв‚‚ : Matrix (Fin n) (Fin n) R) :
    interleaved_quartic Sв‚Ѓ Sв‚‚ - trace (Sв‚Ѓ * Sв‚Ѓ * (Sв‚‚ * Sв‚‚)) =
    trace (Sв‚Ѓ * (Sв‚‚ * Sв‚Ѓ - Sв‚Ѓ * Sв‚‚) * Sв‚‚) := by
      -- By expanding the right-hand side, we can see that the difference is indeed the trace of $Sв‚Ѓ * (Sв‚‚ * Sв‚Ѓ - Sв‚Ѓ * Sв‚‚) * Sв‚‚$.
      simp [interleaved_quartic, mul_sub, sub_mul];
      simp +decide only [mul_assoc]

-- ============================================================
-- SECTION 7: THEOREM D вЂ” the stratification theorem
-- ============================================================

/-- THEOREM D: The non-commutative stratification of charpoly(Mв‚ѓ).

    The characteristic polynomial coefficients of Mв‚ѓ see non-commutativity
    at different levels:

    eв‚ѓ(Mв‚ѓ) = в€Џбµў det(I-ОібµўSбµў):    blind to ALL cross-matrix invariants
    eв‚Ѓ(Mв‚ѓ) = tr(Mв‚ѓ):              sees ONE cubic invariant cв‚ѓв‚‚в‚Ѓ
    eв‚‚(Mв‚ѓ) = (trВІ-tr(Mв‚ѓВІ))/2:    sees degree-4 interleaved quartics pбµўв±ј

    Formal: pбµўв±ј appears in eв‚‚ but NOT in eв‚Ѓ or eв‚ѓ. -/
theorem stratification_theorem (Оів‚Ѓ Оів‚‚ Оів‚ѓ : R)
    (Sв‚Ѓ Sв‚‚ Sв‚ѓ : Matrix (Fin n) (Fin n) R)
    (hSв‚Ѓ : Sв‚ЃбµЂ = Sв‚Ѓ) (hSв‚‚ : Sв‚‚бµЂ = Sв‚‚) (hSв‚ѓ : Sв‚ѓбµЂ = Sв‚ѓ) :
    -- eв‚ѓ does not contain interleaved quartics (proved в€€ det_factorises)
    (det (M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ) =
     det (1 - Оів‚ѓ вЂў Sв‚ѓ) * det (1 - Оів‚‚ вЂў Sв‚‚) * det (1 - Оів‚Ѓ вЂў Sв‚Ѓ)) в€§
    -- eв‚Ѓ contains only ONE cubic invariant cв‚ѓв‚‚в‚Ѓ
    (trace (M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ) =
     (Fintype.card (Fin n) : R)
     - Оів‚Ѓ * trace Sв‚Ѓ - Оів‚‚ * trace Sв‚‚ - Оів‚ѓ * trace Sв‚ѓ
     + Оів‚Ѓ * Оів‚‚ * trace (Sв‚‚ * Sв‚Ѓ)
     + Оів‚Ѓ * Оів‚ѓ * trace (Sв‚ѓ * Sв‚Ѓ)
     + Оів‚‚ * Оів‚ѓ * trace (Sв‚ѓ * Sв‚‚)
     - Оів‚Ѓ * Оів‚‚ * Оів‚ѓ * trace (Sв‚ѓ * Sв‚‚ * Sв‚Ѓ)) := by
       -- By definition of $M3$, we can expand it as a product of three matrices.
       have hM3_expansion : M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ = (1 - Оів‚ѓ вЂў Sв‚ѓ) * (1 - Оів‚‚ вЂў Sв‚‚) * (1 - Оів‚Ѓ вЂў Sв‚Ѓ) := by
         rfl;
       -- Apply the determinant property and the trace expansion to conclude the proof.
       apply And.intro;
       В· rw [ hM3_expansion, Matrix.det_mul, Matrix.det_mul ];
       В· rw [ hM3_expansion ] ; simp +decide [ Matrix.mul_sub, Matrix.sub_mul, Matrix.mul_assoc ] ; ring;

-- ============================================================
-- SECTION 8: The d=3 phase transition вЂ” discriminant structure
-- ============================================================

/-- For a 3Г—3 matrix with charpoly XВі - eв‚ЃXВІ + eв‚‚X - eв‚ѓ,
    the discriminant is:
    О” = eв‚ЃВІeв‚‚ВІ - 4eв‚‚Ві - 4eв‚ЃВіeв‚ѓ + 18eв‚Ѓeв‚‚eв‚ѓ - 27eв‚ѓВІ
    
    О” = 0 iff M has a repeated eigenvalue (the d=3 Rotational Phase Transition). -/
def discriminant3 (eв‚Ѓ eв‚‚ eв‚ѓ : R) : R :=
  eв‚Ѓ ^ 2 * eв‚‚ ^ 2 - 4 * eв‚‚ ^ 3 - 4 * eв‚Ѓ ^ 3 * eв‚ѓ +
  18 * eв‚Ѓ * eв‚‚ * eв‚ѓ - 27 * eв‚ѓ ^ 2

/-- The d=3 Boundary Lemma (structure): the optimal stepsizes lie on
    the surface О”(eв‚Ѓ(Оі), eв‚‚(Оі), eв‚ѓ(Оі)) = 0, where:
    - eв‚ѓ is fixed (det factorises)
    - eв‚Ѓ depends on 7 invariants (cubic max)
    - eв‚‚ depends on all ~25 invariants (quartic, degree-5, degree-6)
    
    The discriminant condition constrains eв‚Ѓ and eв‚‚ jointly. -/
theorem d3_phase_transition_structure (Оів‚Ѓ Оів‚‚ Оів‚ѓ : R)
    (Sв‚Ѓ Sв‚‚ Sв‚ѓ : Matrix (Fin n) (Fin n) R)
    (hSв‚Ѓ : Sв‚ЃбµЂ = Sв‚Ѓ) (hSв‚‚ : Sв‚‚бµЂ = Sв‚‚) (hSв‚ѓ : Sв‚ѓбµЂ = Sв‚ѓ) :
    -- The determinant (eв‚ѓ) is determined solely by individual spectra
    let eв‚ѓ := det (1 - Оів‚ѓ вЂў Sв‚ѓ) * det (1 - Оів‚‚ вЂў Sв‚‚) * det (1 - Оів‚Ѓ вЂў Sв‚Ѓ)
    -- The discriminant surface О” = 0 constrains (eв‚Ѓ, eв‚‚) for fixed eв‚ѓ
    det (M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ) = eв‚ѓ := by
  simp [M3, det_mul]

-- ============================================================
-- SECTION 9: Summary вЂ” invariant hierarchy theorem
-- ============================================================

/-- THEOREM E: The complete invariant hierarchy for K=3, symmetric matrices.
    
    The characteristic polynomial П‡(Mв‚ѓ) = О»Ві - eв‚ЃО»ВІ + eв‚‚О» - eв‚ѓ is determined by:
    
    For eв‚ѓ: 9 invariants вЂ” {tбµў, eв‚‚(Sбµў), det(Sбµў)} for i=1,2,3
    For eв‚Ѓ: 7 invariants вЂ” {tв‚Ѓ,tв‚‚,tв‚ѓ, qв‚Ѓв‚‚,qв‚Ѓв‚ѓ,qв‚‚в‚ѓ, cв‚ѓв‚‚в‚Ѓ}
    For eв‚‚: all of the above PLUS:
              6 degree-3: {rв‚Ѓв‚‚, rв‚Ѓв‚ѓ, rв‚‚в‚Ѓ, rв‚‚в‚ѓ, rв‚ѓв‚Ѓ, rв‚ѓв‚‚}
              9 degree-4: {pв‚Ѓв‚‚, pв‚Ѓв‚ѓ, pв‚‚в‚ѓ, mв‚Ѓв‚Ѓв‚‚в‚ѓ, mв‚Ѓв‚‚в‚Ѓв‚ѓ, mв‚Ѓв‚‚в‚‚в‚ѓ, mв‚Ѓв‚‚в‚ѓв‚‚, mв‚Ѓв‚‚в‚ѓв‚ѓ, mв‚Ѓв‚ѓв‚‚в‚ѓ}
              3 degree-5: {hв‚Ѓв‚‚в‚Ѓв‚‚в‚ѓ, hв‚Ѓв‚‚в‚ѓв‚Ѓв‚ѓ, hв‚Ѓв‚‚в‚ѓв‚‚в‚ѓ}
              1 degree-6: {hв‚Ѓв‚‚в‚ѓв‚Ѓв‚‚в‚ѓ}
    
    Total: the full П‡(Mв‚ѓ) for symmetric d=3 matrices is determined by
    at most ~35 independent invariants (vs 5 at d=2). -/
theorem invariant_hierarchy_K3 (Оів‚Ѓ Оів‚‚ Оів‚ѓ : R)
    (Sв‚Ѓ Sв‚‚ Sв‚ѓ : Matrix (Fin n) (Fin n) R)
    (hSв‚Ѓ : Sв‚ЃбµЂ = Sв‚Ѓ) (hSв‚‚ : Sв‚‚бµЂ = Sв‚‚) (hSв‚ѓ : Sв‚ѓбµЂ = Sв‚ѓ) :
    -- The three characteristic polynomial coefficients have increasing
    -- invariant complexity: eв‚ѓ < eв‚Ѓ < eв‚‚
    -- We record the det and trace results; eв‚‚ is their combination.
    det (M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ) =
    det (1 - Оів‚ѓ вЂў Sв‚ѓ) * det (1 - Оів‚‚ вЂў Sв‚‚) * det (1 - Оів‚Ѓ вЂў Sв‚Ѓ) в€§
    trace (M3 Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ) =
    (Fintype.card (Fin n) : R)
    - Оів‚Ѓ * trace Sв‚Ѓ - Оів‚‚ * trace Sв‚‚ - Оів‚ѓ * trace Sв‚ѓ
    + Оів‚Ѓ * Оів‚‚ * trace (Sв‚‚ * Sв‚Ѓ)
    + Оів‚Ѓ * Оів‚ѓ * trace (Sв‚ѓ * Sв‚Ѓ)
    + Оів‚‚ * Оів‚ѓ * trace (Sв‚ѓ * Sв‚‚)
    - Оів‚Ѓ * Оів‚‚ * Оів‚ѓ * trace (Sв‚ѓ * Sв‚‚ * Sв‚Ѓ) := by
  exact stratification_theorem Оів‚Ѓ Оів‚‚ Оів‚ѓ Sв‚Ѓ Sв‚‚ Sв‚ѓ hSв‚Ѓ hSв‚‚ hSв‚ѓ