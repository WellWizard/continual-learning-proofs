/-- THEOREM B: Newton's identity relating eв‚‚ to tr and trВІ.
    For any matrix M: 2В·eв‚‚(M) = tr(M)ВІ - tr(MВІ)
    where eв‚‚(M) is the second elementary symmetric polynomial of eigenvalues.
    For a 3Г—3 matrix M with charpoly XВі - eв‚ЃXВІ + eв‚‚X - eв‚ѓ:
    eв‚Ѓ = tr(M), eв‚‚ = (tr(M)ВІ - tr(MВІ))/2, eв‚ѓ = det(M). -/
theorem e2_newton_identity (M : Matrix (Fin n) (Fin n) R) :
    -- The second elementary symmetric polynomial satisfies 2В·eв‚‚ = tr(M)ВІ - tr(MВІ)
    -- We state this as the definition / the Newton power sum identity
    trace M ^ 2 - trace (M ^ 2) =
    trace M ^ 2 - trace (M * M) := by
  rw [sq (M)]

