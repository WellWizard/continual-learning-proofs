theorem det_factorises (K : ℕ) (γ : Fin K → R)
    (Sigma : Fin K → Matrix (Fin n) (Fin n) R) :
    det (cycleOp K γ Sigma) = ∏ i : Fin K, det (updateOp (γ i) (Sigma i)) := by
