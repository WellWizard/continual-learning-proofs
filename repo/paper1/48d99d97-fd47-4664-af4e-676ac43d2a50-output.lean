      -- By the properties of determinants, we can expand both sides using the definition of `cycleOp`.
      have h_det_expand : ∀ (γ : Fin K → R) (Sigma : Fin K → Matrix (Fin n) (Fin n) R), Matrix.det (cycleOp K γ Sigma) = ∏ i, Matrix.det (1 - γ i • Sigma i) := by
        -- Apply the determinant factorization theorem to conclude the proof.
        apply det_factorises;
      -- Apply the expansion hypothesis to both Sigma and Sigma'.
      simp [h_det_expand, h]

/-- Expand the product (I - γ₃Σ₃)(I - γ₂Σ₂)(I - γ₁Σ₁) -/
lemma cycle3_expand (γ₁ γ₂ γ₃ : R)
    (S₁ S₂ S₃ : Matrix (Fin n) (Fin n) R) :
    (1 - γ₃ • S₃) * (1 - γ₂ • S₂) * (1 - γ₁ • S₁) =
    1
    - γ₁ • S₁ - γ₂ • S₂ - γ₃ • S₃
    + (γ₁ * γ₂) • (S₂ * S₁) + (γ₁ * γ₃) • (S₃ * S₁) + (γ₂ * γ₃) • (S₃ * S₂)
    - (γ₁ * γ₂ * γ₃) • (S₃ * S₂ * S₁) := by
      -- Expand the product step by step.
      simp [mul_sub, sub_mul, mul_assoc, add_assoc, add_comm, add_left_comm];
      -- Combine like terms and factor out the common coefficients.
      simp [sub_eq_add_neg, add_assoc, add_comm, add_left_comm, mul_assoc, smul_smul] at *

/-- THEOREM 2: Trace expansion for K=3, any d.
    tr(M₃) = d - γ₁t₁ - γ₂t₂ - γ₃t₃
             + γ₁γ₂·tr(S₂S₁) + γ₁γ₃·tr(S₃S₁) + γ₂γ₃·tr(S₃S₂)
             - γ₁γ₂γ₃·tr(S₃S₂S₁)

    Non-commutativity enters only through the cubic term tr(S₃S₂S₁).
    The quadratic terms tr(SᵢSⱼ) are symmetric: tr(SᵢSⱼ) = tr(SⱼSᵢ). -/
theorem trace_expansion_K3 (γ₁ γ₂ γ₃ : R)
    (S₁ S₂ S₃ : Matrix (Fin n) (Fin n) R) :
    trace ((1 - γ₃ • S₃) * (1 - γ₂ • S₂) * (1 - γ₁ • S₁)) =
    (Fintype.card (Fin n) : R)
    - γ₁ * trace S₁ - γ₂ * trace S₂ - γ₃ * trace S₃
    + γ₁ * γ₂ * trace (S₂ * S₁)
    + γ₁ * γ₃ * trace (S₃ * S₁)
    + γ₂ * γ₃ * trace (S₃ * S₂)
    - γ₁ * γ₂ * γ₃ * trace (S₃ * S₂ * S₁) := by
      -- By expanding the product and applying the properties of the trace, we can simplify the expression step by step.
      simp [Matrix.mul_sub, Matrix.sub_mul, Matrix.mul_assoc, Matrix.trace_add, Matrix.trace_sub, Matrix.trace_smul] at *;
      grind

/-- THEOREM 3: The quadratic cross-terms are symmetric.
    tr(SᵢSⱼ) = tr(SⱼSᵢ) for any matrices (cyclic property of trace).
    This means the quadratic part of tr(M₃) sees only the symmetric
