        intro L; induction' L with A L ih <;> simp +decide [ *, Matrix.det_mul ] ;
      generalize_proofs at *;
      -- Apply the determinant property to the list of matrices in the cycleOp.
      convert h_det_prod (List.map (fun i => updateOp (γ (Fin.rev i)) (Sigma (Fin.rev i))) (List.finRange K)) using 1;
      have h_perm : ∏ i : Fin K, (updateOp (γ i) (Sigma i)).det = ∏ i : Fin K, (updateOp (γ (Fin.rev i)) (Sigma (Fin.rev i))).det := by
        apply Finset.prod_bij (fun i _ => Fin.rev i) _ _ _ _ <;> simp +decide [ Finset.mem_univ ];
        exact fun b => ⟨ Fin.rev b, Fin.rev_rev b ⟩
      generalize_proofs at *; (
      rw [ h_perm, ← List.prod_ofFn ] ; simp +decide [ List.ofFn_eq_map ] ;
      rfl);

/-- Corollary: det(M_K) depends only on the individual spectra of Σᵢ,
    not on their mutual commutation relations. -/
theorem det_blind_to_commutator (K : ℕ) (γ : Fin K → R)
    (Sigma Sigma' : Fin K → Matrix (Fin n) (Fin n) R)
    (h : ∀ i, det (1 - γ i • Sigma i) = det (1 - γ i • Sigma' i)) :
