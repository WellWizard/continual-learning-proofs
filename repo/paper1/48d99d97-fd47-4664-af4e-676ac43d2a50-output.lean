/-- Single update operator for task i: Aᵢ = I - γᵢ Σᵢ -/
def updateOp (γ : R) (Sigma : Matrix (Fin n) (Fin n) R) :
    Matrix (Fin n) (Fin n) R :=
  1 - γ • Sigma

/-- K-task cycle operator M_K = A_K ⋯ A₁ (right to left) -/
def cycleOp (K : ℕ) (γ : Fin K → R) (Sigma : Fin K → Matrix (Fin n) (Fin n) R) :
    Matrix (Fin n) (Fin n) R :=
  ((List.finRange K).map (fun i => updateOp (γ (Fin.rev i)) (Sigma (Fin.rev i)))).prod

