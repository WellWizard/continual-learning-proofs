      · erw [ Matrix.det_diagonal, Matrix.adjugate_diagonal ] ; norm_num ; ring!;
      · erw [ Matrix.det_diagonal, Matrix.adjugate_diagonal ] ; norm_num ; ring;
      · erw [ Matrix.det_diagonal, Matrix.adjugate_diagonal ] ; norm_num ; ring;
      · erw [ Matrix.det_diagonal, Matrix.adjugate_diagonal ] ; norm_num ; ring!;

theorem det_decomp_2x2 (a b c_off d_diag c : ℝ) :
    let M : Matrix (Fin 2) (Fin 2) ℝ := !![a, b + c; -c + b, d_diag]
