def sym_part (M : Matrix (Fin 2) (Fin 2) ℝ) : Matrix (Fin 2) (Fin 2) ℝ :=
  (M + Matrix.transpose M) / 2

def skew_scalar (M : Matrix (Fin 2) (Fin 2) ℝ) : ℝ :=
  (M 1 0 - M 0 1) / 2

theorem matrix2x2_skew_decomp (M : Matrix (Fin 2) (Fin 2) ℝ) :
    M = sym_part M - skew_scalar M • J2 := by
      -- Let's expand the right-hand side to verify the equality.
