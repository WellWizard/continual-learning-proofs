  apply mul_le_mul
  · exact k2_D_quadratic_min t₁ d₁ γ₁ hd₁
  · exact k2_D_quadratic_min t₂ d₂ γ₂ hd₂
  · exact hD₂min_pos
  · linarith [k2_D_quadratic_min t₁ d₁ γ₁ hd₁]

theorem k2_complex_opt_rho (t₁ t₂ d₁ d₂ γ₁ γ₂ : ℝ)
    (hd₁ : 0 < d₁) (hd₂ : 0 < d₂)
    (hD₁_pos : 0 ≤ 1 - γ₁ * t₁ + γ₁ ^ 2 * d₁)
    (hD₂_pos : 0 ≤ 1 - γ₂ * t₂ + γ₂ ^ 2 * d₂)
    (hD₁min_pos : 0 ≤ 1 - t₁ ^ 2 / (4 * d₁))
    (hD₂min_pos : 0 ≤ 1 - t₂ ^ 2 / (4 * d₂)) :
    Real.sqrt ((1 - t₁ ^ 2 / (4 * d₁)) * (1 - t₂ ^ 2 / (4 * d₂))) ≤
