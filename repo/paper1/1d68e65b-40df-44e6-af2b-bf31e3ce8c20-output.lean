  exact k2_unified_lb T D hT hD

theorem k2_complex_global_opt (t₁ t₂ d₁ d₂ γ₁ γ₂ : ℝ)
    (hd₁ : 0 < d₁) (hd₂ : 0 < d₂)
    (hD₁_pos : 0 ≤ 1 - γ₁ * t₁ + γ₁ ^ 2 * d₁)
    (hD₂_pos : 0 ≤ 1 - γ₂ * t₂ + γ₂ ^ 2 * d₂)
    (hD₁min_pos : 0 ≤ 1 - t₁ ^ 2 / (4 * d₁))
    (hD₂min_pos : 0 ≤ 1 - t₂ ^ 2 / (4 * d₂)) :
    -- ρ at optimal γ* ≤ ρ at any other γ
    Real.sqrt ((1 - t₁ ^ 2 / (4 * d₁)) * (1 - t₂ ^ 2 / (4 * d₂))) ≤
    Real.sqrt ((1 - γ₁ * t₁ + γ₁ ^ 2 * d₁) * (1 - γ₂ * t₂ + γ₂ ^ 2 * d₂)) :=
  k2_complex_opt_rho t₁ t₂ d₁ d₂ γ₁ γ₂ hd₁ hd₂
    hD₁_pos hD₂_pos hD₁min_pos hD₂min_pos

theorem k2_real_boundary_min (T D : ℝ) (hT : 0 ≤ T)
    (hinterior : 4 * D < T ^ 2) :
    T / 2 < (T + Real.sqrt (T ^ 2 - 4 * D)) / 2 :=
  k2_real_regime_min_at_boundary T D hT hinterior

theorem k2_global_optimality (T D : ℝ) (hT : 0 ≤ T) (hD : 0 ≤ D) :
    -- Lower bound holds universally
    T / 2 ≤ (if T ^ 2 ≤ 4 * D then Real.sqrt D
             else (T + Real.sqrt (T ^ 2 - 4 * D)) / 2) ∧
    -- Boundary value achieves T/2 (real regime formula at D=T²/4)
    (T + Real.sqrt (T ^ 2 - 4 * (T ^ 2 / 4))) / 2 = T / 2 ∧
    -- Boundary value achieves T/2 (complex regime formula at D=T²/4)
    Real.sqrt (T ^ 2 / 4) = T / 2 := by
  refine ⟨k2_unified_lb T D hT hD, ?_, ?_⟩
  · -- Real regime at boundary
    have : T ^ 2 - 4 * (T ^ 2 / 4) = 0 := by ring
    simp [this, Real.sqrt_zero]
  · -- Complex regime at boundary: √(T²/4) = T/2
    rw [show T ^ 2 / 4 = (T / 2) ^ 2 by ring]
    exact Real.sqrt_sq (by linarith)

theorem k2_rho_real_approaches_half_trace (T D : ℝ) (hT : 0 ≤ T) (hD : 0 ≤ D)
    (hreal : 4 * D ≤ T ^ 2) :
    (T + Real.sqrt (T ^ 2 - 4 * D)) / 2 ≤ (T + Real.sqrt (T ^ 2)) / 2 := by
  have h1 : T ^ 2 - 4 * D ≤ T ^ 2 := by linarith
  have h2 : 0 ≤ T ^ 2 - 4 * D := by linarith
  have hsq : Real.sqrt (T ^ 2 - 4 * D) ≤ Real.sqrt (T ^ 2) :=
    Real.sqrt_le_sqrt h1
  linarith