  apply Real.sqrt_le_sqrt
  exact k2_D_product_min t₁ t₂ d₁ d₂ γ₁ γ₂ hd₁ hd₂
    hD₁_pos hD₂_pos hD₁min_pos hD₂min_pos

theorem k2_real_regime_min_at_boundary (T D : ℝ) (hT : 0 ≤ T)
    (hreal : 4 * D < T ^ 2) :
    T / 2 < (T + Real.sqrt (T ^ 2 - 4 * D)) / 2 := by
  have hsqrt_pos : 0 < Real.sqrt (T ^ 2 - 4 * D) := by
    apply Real.sqrt_pos_of_pos
    linarith
  linarith

theorem k2_real_rho_eq_half_iff (T D : ℝ) (hT : 0 ≤ T) (hreal : 4 * D ≤ T ^ 2) :
    (T + Real.sqrt (T ^ 2 - 4 * D)) / 2 = T / 2 ↔ T ^ 2 = 4 * D := by
  constructor
  · intro h
    have hsq : Real.sqrt (T ^ 2 - 4 * D) = 0 := by linarith
    rw [Real.sqrt_eq_zero'] at hsq
    linarith
  · intro h
    rw [show T ^ 2 - 4 * D = 0 by linarith, Real.sqrt_zero]
    ring

theorem k2_master_optimality (T D : ℝ) (hT : 0 ≤ T) (hD : 0 ≤ D) :
    -- In real regime: ρ ≥ T/2
    (4 * D ≤ T ^ 2 → T / 2 ≤ (T + Real.sqrt (T ^ 2 - 4 * D)) / 2) ∧
    -- In complex regime: ρ ≥ T/2
    (T ^ 2 < 4 * D → T / 2 ≤ Real.sqrt D) ∧
    -- Boundary value: T/2 is achieved
    (T + Real.sqrt (T ^ 2 - 4 * (T ^ 2 / 4))) / 2 = T / 2 := by
      -- By combining the results from the two cases, we can conclude the proof.
      apply And.intro;
      · -- By simplifying, we can see that this inequality holds because the square root function is non-negative.
        intros hD_le
        linarith [Real.sqrt_nonneg (T^2 - 4 * D)];
      · -- For the first part, if $T^2 < 4D$, then $D > T^2 / 4$, so $\sqrt{D} > T / 2$.
        apply And.intro
        intro h
        have h_sqrt : Real.sqrt D > T / 2 := by
          exact Real.lt_sqrt_of_sq_lt ( by linarith )
        linarith
        -- For the second part, simplify the expression inside the square root.
        field_simp [mul_comm, mul_assoc, mul_left_comm];
        -- Simplify the expression inside the square root: $T^2 * (1 - 1) = T^2 * 0 = 0$.
        simp [mul_zero, sub_self]

theorem k2_rho_geq_half_trace (T D : ℝ) (hT : 0 ≤ T) (hD : 0 ≤ D) :
    (if T ^ 2 ≤ 4 * D then Real.sqrt D else (T + Real.sqrt (T ^ 2 - 4 * D)) / 2)
