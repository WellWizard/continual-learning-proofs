  linarith

theorem k2_rho_complex_lb (T D : ℝ) (hT : 0 ≤ T) (hD : 0 ≤ D)
    (hcomplex : T ^ 2 < 4 * D) :
    T / 2 ≤ Real.sqrt D := by
      -- Since $T^2 < 4D$, taking the square root of both sides gives $T < 2\sqrt{D}$.
      have h_sqrt : T < 2 * Real.sqrt D := by
        -- Taking the square root of both sides of $T^2 < 4D$, we get $T < \sqrt{4D}$.
        have h_sqrt : T < Real.sqrt (4 * D) := by
          -- Since $T$ is non-negative, taking the square root of both sides of $T^2 < 4D$ preserves the inequality.
          apply Real.lt_sqrt_of_sq_lt; exact hcomplex;
        -- Since $\sqrt{4D} = 2\sqrt{D}$, we can conclude that $T < 2\sqrt{D}$.
        rw [Real.sqrt_mul (by norm_num)] at h_sqrt
        norm_num at h_sqrt
        exact h_sqrt;
      -- By dividing both sides of the inequality $T < 2 * \sqrt{D}$ by 2, we obtain $T / 2 < \sqrt{D}$.
      linarith [h_sqrt]

theorem k2_rho_complex_lb_strict (T D : ℝ) (hT : 0 < T) (hD : 0 < D)
    (hcomplex : T ^ 2 < 4 * D) :
    T / 2 < Real.sqrt D := by
      -- Taking the square root of both sides of $T^2 / 4 < D$, we get $T / 2 < \sqrt{D}$.
      apply Real.lt_sqrt_of_sq_lt; linarith

theorem k2_unified_lb (T D : ℝ) (hT : 0 ≤ T) (hD : 0 ≤ D) :
    (if T ^ 2 ≤ 4 * D
     then Real.sqrt D          -- complex regime
     else (T + Real.sqrt (T ^ 2 - 4 * D)) / 2)  -- real regime
    ≥ T / 2 := by
      -- Consider the two cases: $T^2 \leq 4D$ and $T^2 > 4D$.
      by_cases h_case : T^2 ≤ 4 * D;
      · -- Since $T$ is non-negative, we have $T^2 \leq 4D$ implies $T \leq 2\sqrt{D}$.
        have h_sqrt : T ≤ 2 * Real.sqrt D := by
          nlinarith [ Real.sqrt_nonneg D, Real.sq_sqrt hD ];
        split_ifs ; linarith [ Real.sqrt_nonneg D ] ;
      · -- Since $T^2 > 4D$, we have $\sqrt{T^2 - 4D} \geq 0$, thus $(T + \sqrt{T^2 - 4D}) / 2 \geq T / 2$.
        simp [h_case];
        -- Since $T^2 > 4D$, we have $\sqrt{T^2 - 4D} \geq 0$, thus $0 \leq \sqrt{T^2 - 4D}$.
        apply div_le_div_of_nonneg_right (by linarith [Real.sqrt_nonneg (T^2 - 4 * D)]) (by norm_num)

theorem k2_min_is_half_trace (T : ℝ) (hT : 0 ≤ T) :
    (if T ^ 2 ≤ 4 * (T ^ 2 / 4)
     then Real.sqrt (T ^ 2 / 4)
     else (T + Real.sqrt (T ^ 2 - 4 * (T ^ 2 / 4))) / 2) = T / 2 := by
       -- Since $T^2 \leq 4 * (T^2 / 4)$ simplifies to $T^2 \leq T^2$, which is always true, the if statement evaluates to true.
       simp [mul_div_cancel₀];
       -- Since $T$ is non-negative, we have $\sqrt{T^2} = T$.
       rw [Real.sqrt_sq hT]
       norm_num

theorem k2_D_quadratic_min (t d γ : ℝ) (hd : 0 < d) :
    1 - t ^ 2 / (4 * d) ≤ 1 - γ * t + γ ^ 2 * d := by
      -- By multiplying both sides of the inequality by $4d$, we can eliminate the denominator and simplify the expression.
      have h_mul : -t^2 ≤ -4 * d * γ * t + 4 * d^2 * γ^2 := by
        -- By completing the square, we can rewrite the inequality as $(t - 2d\gamma)^2 \geq 0$, which is always true.
        have h_complete_square : (t - 2 * d * γ) ^ 2 ≥ 0 := by
          -- The square of any real number is non-negative.
          apply sq_nonneg
        linarith [h_complete_square]
      generalize_proofs at *; (
      -- By dividing both sides of the inequality by $4d$, we can eliminate the denominator and simplify the expression.
      field_simp [hd] at *; linarith [h_mul])

theorem k2_D_quadratic_min_achieved (t d : ℝ) (hd : 0 < d) :
    1 - (t / (2 * d)) * t + (t / (2 * d)) ^ 2 * d = 1 - t ^ 2 / (4 * d) := by
  field_simp
  ring

theorem k2_D_product_min (t₁ t₂ d₁ d₂ γ₁ γ₂ : ℝ)
    (hd₁ : 0 < d₁) (hd₂ : 0 < d₂)
    (hD₁_pos : 0 ≤ 1 - γ₁ * t₁ + γ₁ ^ 2 * d₁)
    (hD₂_pos : 0 ≤ 1 - γ₂ * t₂ + γ₂ ^ 2 * d₂)
    (hD₁min_pos : 0 ≤ 1 - t₁ ^ 2 / (4 * d₁))
    (hD₂min_pos : 0 ≤ 1 - t₂ ^ 2 / (4 * d₂)) :
