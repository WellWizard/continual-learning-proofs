theorem k2_rho_real_lb (T D : ℝ) (hT : 0 ≤ T) (hreal : 4 * D ≤ T ^ 2) :
    T / 2 ≤ (T + Real.sqrt (T ^ 2 - 4 * D)) / 2 := by
  have hsqrt : 0 ≤ Real.sqrt (T ^ 2 - 4 * D) := Real.sqrt_nonneg _
  linarith

theorem k2_boundary_rho_eq (T : ℝ) (hT : 0 ≤ T) :
    (T + Real.sqrt (T ^ 2 - 4 * (T ^ 2 / 4))) / 2 = T / 2 := by
  have : T ^ 2 - 4 * (T ^ 2 / 4) = 0 := by ring
  simp [this, Real.sqrt_zero]

theorem k2_rho_real_antitone_D (T D₁ D₂ : ℝ) (hT : 0 ≤ T)
    (hD1 : 4 * D₁ ≤ T ^ 2) (hD2 : D₁ < D₂) (hD2_bound : 4 * D₂ ≤ T ^ 2) :
    (T + Real.sqrt (T ^ 2 - 4 * D₂)) / 2 < (T + Real.sqrt (T ^ 2 - 4 * D₁)) / 2 := by
  have h1 : T ^ 2 - 4 * D₂ < T ^ 2 - 4 * D₁ := by linarith
  have h2 : 0 ≤ T ^ 2 - 4 * D₂ := by linarith
  have hsq : Real.sqrt (T ^ 2 - 4 * D₂) < Real.sqrt (T ^ 2 - 4 * D₁) :=
