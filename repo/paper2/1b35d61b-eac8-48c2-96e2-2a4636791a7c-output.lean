Checking Norm instance and Matrix.reindex
-/
open scoped Matrix.Norms.L2Operator
variable (n : ℕ)
#synth Norm (Matrix (Fin n) (Fin n) ℂ)
#check Matrix.reindex

/-
Checking equality of toLin' and toLinAlgEquiv'
-/
open scoped Matrix.Norms.L2Operator
variable {d : ℕ} (M : Matrix (Fin d) (Fin d) ℂ)
#check Matrix.toLinAlgEquiv' M
#check Matrix.toLin' M
example : (Matrix.toLinAlgEquiv' M : (Fin d → ℂ) →ₗ[ℂ] (Fin d → ℂ)) = Matrix.toLin' M := rfl

/-
If M = S + N with S, N commuting, S diagonalizable, N nilpotent, and ρ(S) > 0, then ‖M^n‖ is bounded by C * n^(k-1) * ρ(S)^n.
-/
open scoped Matrix.Norms.L2Operator

theorem bound_of_commuting_semisimple_nilpotent {d : ℕ} (S N : Matrix (Fin d) (Fin d) ℂ) (k : ℕ) (hk : 0 < k)
  (h_comm : Commute S N) (h_nil : N ^ k = 0)
  (h_diag : ∃ P : Matrix (Fin d) (Fin d) ℂ, IsUnit P ∧ (P * S * P⁻¹).IsDiag)
  (h_rho_pos : 0 < (spectralRadius ℂ S).toReal) :
  ∃ C > 0, ∀ n : ℕ, ‖(S + N) ^ n‖ ≤ C * (n + 1) ^ (k - 1) * ((spectralRadius ℂ S).toReal) ^ n := by
    -- Let $P$ be a matrix such that $PSP^{-1}$ is diagonal.
    obtain ⟨P, hP_unit, hP_diag⟩ := h_diag
    set D := P * S * P⁻¹
    have hD_diag : D.IsDiag := by
      exact hP_diag
    have hD_eigenvalues : ∀ i, ‖D i i‖ ≤ (spectralRadius ℂ S).toReal := by
      intro i
      have h_eigenvalue : ∀ (μ : ℂ), μ ∈ spectrum ℂ (P * S * P⁻¹) → ‖μ‖ ≤ (spectralRadius ℂ S).toReal := by
        intro μ hμ
        have h_eigenvalue : μ ∈ spectrum ℂ S := by
          simp_all +decide [ spectrum.mem_iff, Matrix.isUnit_iff_isUnit_det ];
          rw [ show ( algebraMap ℂ ( Matrix ( Fin d ) ( Fin d ) ℂ ) ) μ - P * S * P⁻¹ = P * ( ( algebraMap ℂ ( Matrix ( Fin d ) ( Fin d ) ℂ ) ) μ - S ) * P⁻¹ from ?_, Matrix.det_mul, Matrix.det_mul ] at hμ ; aesop
          generalize_proofs at *; (
          simp +decide [ mul_sub, sub_mul, mul_assoc, hP_unit, isUnit_iff_ne_zero ];
          simp +decide [ Algebra.algebraMap_eq_smul_one, mul_assoc, hP_unit, isUnit_iff_ne_zero ])
        generalize_proofs at *;
        refine' le_trans _ ( ENNReal.toReal_mono _ <| le_ciSup _ μ ) <;> norm_num [ h_eigenvalue ];
        contrapose! h_rho_pos; aesop;
      generalize_proofs at *;
      apply h_eigenvalue
      generalize_proofs at *; (
      rw [ spectrum.mem_iff ];
      simp_all +decide [ Matrix.isUnit_iff_isUnit_det ];
      rw [ ← Matrix.exists_mulVec_eq_zero_iff ];
      refine' ⟨ Pi.single i 1, _, _ ⟩ <;> simp_all +decide [ funext_iff, Matrix.mulVec ];
      · exact ⟨ i, by simp +decide ⟩;
      · intro x; by_cases hx : x = i <;> simp_all +decide [ Algebra.algebraMap_eq_smul_one ] ;
        · exact sub_self _;
        · exact hP_diag hx)
    have hD_pow : ∀ n, ‖D ^ n‖ ≤ (spectralRadius ℂ S).toReal ^ n := by
      intro n
      have hD_pow_diag : D ^ n = Matrix.diagonal (fun i => (D i i) ^ n) := by
        induction n <;> simp_all +decide [ pow_succ, Matrix.mul_assoc ];
        ext i j; by_cases hi : i = j <;> aesop;
      have hD_pow_norm : ‖D ^ n‖ ≤ (spectralRadius ℂ S).toReal ^ n := by
        rw [ hD_pow_diag ];
        refine' csInf_le _ _ <;> norm_num [ hD_eigenvalues ];
        · exact ⟨ 0, fun c hc => hc.1 ⟩;
        · intro x; rw [ EuclideanSpace.norm_eq ] ; simp +decide [ Matrix.toEuclideanLin, Matrix.mulVec ] ; (
          rw [ Real.sqrt_le_iff ] ; norm_num [ EuclideanSpace.norm_eq ] ; ring_nf ; (
          exact ⟨ by positivity, by rw [ Real.sq_sqrt <| Finset.sum_nonneg fun _ _ => sq_nonneg _ ] ; exact le_trans ( Finset.sum_le_sum fun _ _ => mul_le_mul_of_nonneg_right ( pow_le_pow_left₀ ( by positivity ) ( hD_eigenvalues _ ) _ ) <| sq_nonneg _ ) <| by simp +decide [ pow_mul', mul_assoc, mul_comm, mul_left_comm, Finset.mul_sum _ _ _ ] ⟩ ;););
      exact hD_pow_norm
      skip
    have hS_pow : ∀ n, ‖S ^ n‖ ≤ ‖P‖ * ‖P⁻¹‖ * (spectralRadius ℂ S).toReal ^ n := by
      intro n
      have hS_pow_step : ‖S ^ n‖ ≤ ‖P⁻¹‖ * ‖D ^ n‖ * ‖P‖ := by
        have hS_pow_step : S ^ n = P⁻¹ * D ^ n * P := by
          induction n <;> simp_all +decide [ pow_succ, mul_assoc ];
          · cases hP_unit.nonempty_invertible ; aesop;
          · cases hP_unit.nonempty_invertible ; aesop
        generalize_proofs at *; (
        rw [hS_pow_step];
        exact le_trans ( norm_mul_le _ _ ) ( mul_le_mul_of_nonneg_right ( norm_mul_le _ _ ) ( norm_nonneg _ ) ) |> le_trans <| by norm_num [ mul_assoc ] ;)
      generalize_proofs at *; (
      exact hS_pow_step.trans ( by nlinarith [ hD_pow n, show 0 ≤ ‖P‖ * ‖P⁻¹‖ by positivity ] ))
    generalize_proofs at *; (
    -- Expand $(S+N)^n$ using the binomial theorem (valid since $S, N$ commute).
    have h_binom : ∀ n, (S + N) ^ n = ∑ j ∈ Finset.range (k), Nat.choose n j • S ^ (n - j) * N ^ j := by
      intro n
      have h_binom : (S + N) ^ n = ∑ j ∈ Finset.range (n + 1), Nat.choose n j • S ^ (n - j) * N ^ j := by
        have := h_comm.add_pow n
        generalize_proofs at *; (
        rw [ this, ← Finset.sum_flip ];
        refine' Finset.sum_congr rfl fun x hx => _ ; rw [ Nat.choose_symm ( Finset.mem_range_succ_iff.mp hx ), tsub_tsub_cancel_of_le ( Finset.mem_range_succ_iff.mp hx ) ] ; simp +decide [ mul_assoc, mul_comm, mul_left_comm, Algebra.smul_def ] ;
        simp +decide [ ← mul_assoc, ← Nat.cast_comm ])
      generalize_proofs at *; (
      by_cases hn : n < k <;> simp_all +decide [ Finset.sum_range_add_sum_Ico ];
      · rw [ Finset.sum_subset ( Finset.range_mono ( Nat.succ_le_of_lt hn ) ) fun x hx₁ hx₂ => by rw [ Nat.choose_eq_zero_of_lt ] <;> aesop ];
      · rw [ ← Finset.sum_range_add_sum_Ico _ ( by linarith : k ≤ n + 1 ) ] ; simp_all +decide [ pow_add, pow_mul, mul_assoc ] ;
        exact Finset.sum_eq_zero fun x hx => by rw [ pow_eq_zero_of_le ( Finset.mem_Ico.mp hx |>.1 ) h_nil ] ; norm_num;)
    generalize_proofs at *; (
    -- Bound the norm of each term in the sum.
    have h_term_bound : ∀ n j, j < k → ‖Nat.choose n j • S ^ (n - j) * N ^ j‖ ≤ Nat.choose n j * ‖P‖ * ‖P⁻¹‖ * (spectralRadius ℂ S).toReal ^ (n - j) * ‖N ^ j‖ := by
      intros n j hj_lt_k
      have h_term_bound : ‖Nat.choose n j • S ^ (n - j) * N ^ j‖ ≤ Nat.choose n j * ‖S ^ (n - j)‖ * ‖N ^ j‖ := by
        refine' le_trans ( norm_mul_le _ _ ) _;
        gcongr;
        convert norm_smul_le ( n.choose j : ℂ ) ( S ^ ( n - j ) ) using 1 ; norm_num [ Algebra.smul_def ];
        norm_num [ Norm.norm ]
      generalize_proofs at *; (
      exact h_term_bound.trans ( by simpa only [ mul_assoc ] using mul_le_mul_of_nonneg_right ( mul_le_mul_of_nonneg_left ( hS_pow _ ) ( Nat.cast_nonneg _ ) ) ( norm_nonneg _ ) ) ;)
    generalize_proofs at *; (
    -- Using the bound on the binomial coefficients, we get:
    have h_binom_bound : ∀ n, ∑ j ∈ Finset.range k, Nat.choose n j * ‖P‖ * ‖P⁻¹‖ * (spectralRadius ℂ S).toReal ^ (n - j) * ‖N ^ j‖ ≤ (‖P‖ * ‖P⁻¹‖ * (∑ j ∈ Finset.range k, ‖N ^ j‖ / (spectralRadius ℂ S).toReal ^ j)) * (n + 1) ^ (k - 1) * (spectralRadius ℂ S).toReal ^ n := by
      intro n
      have h_binom_bound : ∀ j < k, Nat.choose n j ≤ (n + 1) ^ (k - 1) := by
        intro j hj
        have h_binom_bound : Nat.choose n j ≤ (n + 1) ^ j := by
          exact le_trans ( Nat.choose_le_pow _ _ ) ( by gcongr ; linarith )
        generalize_proofs at *; (
        exact le_trans h_binom_bound ( pow_le_pow_right₀ ( by linarith ) ( Nat.le_pred_of_lt hj ) ))
      generalize_proofs at *; (
      have h_binom_bound : ∀ j < k, Nat.choose n j * ‖P‖ * ‖P⁻¹‖ * (spectralRadius ℂ S).toReal ^ (n - j) * ‖N ^ j‖ ≤ ‖P‖ * ‖P⁻¹‖ * ‖N ^ j‖ / (spectralRadius ℂ S).toReal ^ j * (n + 1) ^ (k - 1) * (spectralRadius ℂ S).toReal ^ n := by
        intro j hj
        have h_binom_bound : Nat.choose n j * (spectralRadius ℂ S).toReal ^ (n - j) ≤ (n + 1) ^ (k - 1) * (spectralRadius ℂ S).toReal ^ n / (spectralRadius ℂ S).toReal ^ j := by
          rw [ le_div_iff₀ ( pow_pos h_rho_pos _ ) ];
          convert mul_le_mul_of_nonneg_right ( Nat.cast_le.mpr ( h_binom_bound j hj ) ) ( pow_nonneg h_rho_pos.le n ) using 1 ; ring;
          · by_cases h : j ≤ n <;> simp_all +decide [ mul_assoc, ← pow_add ];
            exact Or.inr <| Nat.choose_eq_zero_of_lt h;
          · norm_cast
        generalize_proofs at *; (
        convert mul_le_mul_of_nonneg_right h_binom_bound ( show 0 ≤ ‖P‖ * ‖P⁻¹‖ * ‖N ^ j‖ by positivity ) using 1 <;> ring;)
      generalize_proofs at *; (
      convert Finset.sum_le_sum fun j hj => h_binom_bound j ( Finset.mem_range.mp hj ) using 1 ; norm_num [ Finset.mul_sum _ _ _, Finset.sum_mul ] ; ring;
      ac_rfl))
    generalize_proofs at *; (
    refine' ⟨ ‖P‖ * ‖P⁻¹‖ * ∑ j ∈ Finset.range k, ‖N ^ j‖ / ( spectralRadius ℂ S |> ENNReal.toReal ) ^ j + 1, _, _ ⟩ <;> norm_num [ h_binom ] at *;
    · exact add_pos_of_nonneg_of_pos ( mul_nonneg ( mul_nonneg ( norm_nonneg _ ) ( norm_nonneg _ ) ) ( Finset.sum_nonneg fun _ _ => div_nonneg ( norm_nonneg _ ) ( pow_nonneg h_rho_pos.le _ ) ) ) zero_lt_one;
    · intro n; refine' le_trans ( norm_sum_le _ _ ) _ ; refine' le_trans ( Finset.sum_le_sum fun j hj => h_term_bound n j ( Finset.mem_range.mp hj ) ) _ ; refine' le_trans ( h_binom_bound n ) _ ; ring_nf; norm_num;
      field_simp;
      exact le_add_of_nonneg_right zero_le_one))))

/-
If S is diagonalizable, then ‖S^n‖ is bounded by C * ρ(S)^n.
-/
open scoped Matrix.Norms.L2Operator

theorem norm_pow_diagonalizable_bound {d : ℕ} (S : Matrix (Fin d) (Fin d) ℂ)
  (h_diag : ∃ P : Matrix (Fin d) (Fin d) ℂ, IsUnit P ∧ (P * S * P⁻¹).IsDiag) :
  ∃ C > 0, ∀ n : ℕ, ‖S ^ n‖ ≤ C * ((spectralRadius ℂ S).toReal) ^ n := by
    by_cases hS : S = 0 <;> simp_all +decide [ Matrix.nonsing_inv_apply_not_isUnit ];
    · refine' ⟨ 1, by norm_num, fun n => _ ⟩ ; cases n <;> norm_num [ Norm.norm ];
      refine' csInf_le _ _ <;> norm_num [ Norm.norm ];
      · exact ⟨ 0, fun c hc => hc.1 ⟩;
      · simp +decide [ Matrix.toEuclideanLin ];
    · obtain ⟨ P, hP_unit, hP_diag ⟩ := h_diag
      have hP_inv : IsUnit P := by
        exact hP_unit
      have hP_inv_norm : 0 < ‖P‖ ∧ 0 < ‖P⁻¹‖ := by
        cases d <;> simp_all +decide [ Matrix.isUnit_iff_isUnit_det ];
        · exact hS ( Subsingleton.elim _ _ );
        · exact ⟨ by aesop_cat, by intro h; simpa [ h, hP_inv ] using congr_arg Matrix.det ( Matrix.nonsing_inv_mul _ <| show IsUnit P.det from isUnit_iff_ne_zero.mpr hP_inv ) ⟩
      have hP_diag_norm : ∀ n : ℕ, ‖(P * S * P⁻¹) ^ n‖ ≤ (spectralRadius ℂ S).toReal ^ n := by
        intro n
        have hP_diag_norm : ∀ i : Fin d, ‖(P * S * P⁻¹) i i‖ ≤ (spectralRadius ℂ S).toReal := by
          intro i
          have h_eigenvalue : (P * S * P⁻¹) i i ∈ spectrum ℂ S := by
            simp_all +decide [ spectrum.mem_iff, Matrix.isUnit_iff_isUnit_det ];
            have h_eigenvalue : Matrix.det (P * (S - (P * S * P⁻¹) i i • 1) * P⁻¹) = 0 := by
              simp_all +decide [ mul_sub, sub_mul, mul_assoc ];
              rw [ ← Matrix.exists_mulVec_eq_zero_iff ];
              refine' ⟨ Pi.single i 1, _, _ ⟩ <;> simp_all +decide [ funext_iff, Matrix.mulVec, dotProduct ];
              · exact ⟨ i, by simp +decide ⟩;
              · intro x; by_cases hx : x = i <;> simp_all +decide [ Matrix.one_apply ] ;
                exact hP_diag hx
            generalize_proofs at *;
            simp_all +decide [ Matrix.det_mul, Algebra.algebraMap_eq_smul_one ];
            rw [ ← neg_sub, Matrix.det_neg ] ; aesop
          generalize_proofs at *;
          refine' le_trans _ ( ENNReal.toReal_mono _ <| le_ciSup _ <| ( P * S * P⁻¹ ) i i ) <;> norm_num [ h_eigenvalue ];
          simp +decide [ spectralRadius ];
          -- Since the spectrum of S is finite, the supremum of the norms of its elements is finite.
          have h_spectrum_finite : Set.Finite (spectrum ℂ S) := by
            exact?
          generalize_proofs at *; (
          rw [ iSup_eq_top ];
          simp +zetaDelta at *;
          exact ⟨ ∑ x ∈ h_spectrum_finite.toFinset, ‖x‖₊, ENNReal.sum_lt_top.mpr fun x hx => ENNReal.coe_lt_top, fun x hx => by simpa using Finset.single_le_sum ( fun x _ => zero_le ( ‖x‖₊ : ENNReal ) ) ( h_spectrum_finite.mem_toFinset.mpr hx ) ⟩)
        generalize_proofs at *;
        have hP_diag_pow : (P * S * P⁻¹) ^ n = Matrix.diagonal (fun i => ((P * S * P⁻¹) i i) ^ n) := by
          induction n <;> simp_all +decide [ pow_succ, Matrix.diagonal_pow ];
          ext i j; by_cases hi : i = j <;> aesop;
        generalize_proofs at *;
        simp_all +decide [ Matrix.norm_def ];
        refine' csInf_le _ _ <;> norm_num [ hP_diag_norm ];
        · exact ⟨ 0, fun c hc => hc.1 ⟩;
        · intro x; rw [ EuclideanSpace.norm_eq ] ; simp +decide [ Matrix.toEuclideanLin, Matrix.mulVec ] ; (
          rw [ Real.sqrt_le_left ] <;> norm_num [ mul_pow, Finset.mul_sum _ _ _, EuclideanSpace.norm_eq ];
          · rw [ Real.sq_sqrt <| Finset.sum_nonneg fun _ _ => sq_nonneg _ ] ; exact le_trans ( Finset.sum_le_sum fun _ _ => mul_le_mul_of_nonneg_right ( pow_le_pow_left₀ ( by positivity ) ( pow_le_pow_left₀ ( by positivity ) ( hP_diag_norm _ ) _ ) _ ) <| sq_nonneg _ ) <| by simp +decide [ Finset.mul_sum _ _ _, mul_assoc, mul_comm, mul_left_comm ] ;
          · exact mul_nonneg ( pow_nonneg ( ENNReal.toReal_nonneg ) _ ) ( Real.sqrt_nonneg _ ));
      generalize_proofs at *;
      -- Using the fact that $S^n = P^{-1} (P S P^{-1})^n P$, we can bound $\|S^n\|$.
      have hS_pow : ∀ n : ℕ, S ^ n = P⁻¹ * (P * S * P⁻¹) ^ n * P := by
        intro n; induction n <;> simp_all +decide [ pow_succ, mul_assoc ] ;
        · cases hP_unit.nonempty_invertible ; aesop;
        · cases hP_unit.nonempty_invertible ; aesop
      generalize_proofs at *; (
      refine' ⟨ ‖P⁻¹‖ * ‖P‖, mul_pos hP_inv_norm.2 hP_inv_norm.1, fun n => _ ⟩ ; rw [ hS_pow ] ; (
      refine' le_trans _ ( mul_le_mul_of_nonneg_left ( hP_diag_norm n ) ( mul_nonneg hP_inv_norm.2.le hP_inv_norm.1.le ) ) ; ring_nf ; (
      exact le_trans ( norm_mul_le _ _ ) ( by rw [ mul_right_comm ] ; exact mul_le_mul_of_nonneg_right ( norm_mul_le _ _ ) ( norm_nonneg _ ) ) ;));)