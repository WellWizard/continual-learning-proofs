    exact ⟨ C, hC.1, fun n => le_trans ( h_norm n ) ( le_trans ( h_binom n ) ( by nlinarith [ show 0 ≤ ( n + 1 : ℝ ) ^ ( k - 1 ) * ‖c‖ ^ n by positivity, hC.2 n ] ) ) ⟩

