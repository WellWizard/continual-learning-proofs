/-- For any ρ < 1 and any α > 0, there exists N such that for all n ≥ N,
    (n+1)² · ρ^(2n) < 1/(n+1)^α. This is the exponential-vs-polynomial
    separation. -/
theorem exp_poly_separation
    (ρ : ℝ) (hρ₀ : 0 < ρ) (hρ₁ : ρ < 1)
    (α : ℝ) (hα : 0 < α) :
    ∃ N : ℕ, ∀ n : ℕ, N ≤ n →
      (↑n + 1 : ℝ) ^ 2 * ρ ^ (2 * n) < 1 / (↑n + 1) ^ α := by
  -- We want $(n+1)^{2+\alpha} \rho^{2n} < 1$.
  suffices h_exp_poly : Filter.Tendsto (fun n : ℕ => (n + 1 : ℝ) ^ (2 + α) * ρ ^ (2 * n)) Filter.atTop (nhds 0) by
    -- Since the expression tends to 0, there exists an N such that for all n ≥ N, the expression is less than 1.
    obtain ⟨N, hN⟩ : ∃ N : ℕ, ∀ n ≥ N, (n + 1 : ℝ) ^ (2 + α) * ρ ^ (2 * n) < 1 := by
      simpa using h_exp_poly.eventually ( gt_mem_nhds zero_lt_one );
    use N; intro n hn; have := hN n hn; rw [ lt_div_iff₀ ( by positivity ) ] ; convert this using 1 ; rw [ Real.rpow_add ( by positivity ), Real.rpow_two ] ; ring;
  -- We can use the fact that for any fixed $k$, the limit of $n^k \cdot r^n$ as $n$ approaches infinity is 0 when $|r| < 1$.
  have h_exp_poly : ∀ k : ℕ, ∀ r : ℝ, |r| < 1 → Filter.Tendsto (fun n : ℕ => (n : ℝ) ^ k * r ^ n) Filter.atTop (nhds 0) := by
    exact?;
  -- Apply the exponential polynomial limit result with $k = 2 + \alpha$ and $r = \rho^2$.
  have h_exp_poly_applied : Filter.Tendsto (fun n : ℕ => (n : ℝ) ^ (2 + α) * ρ ^ (2 * n)) Filter.atTop (nhds 0) := by
    have h_exp_poly_applied : Filter.Tendsto (fun n : ℕ => (n : ℝ) ^ (2 + ⌈α⌉₊) * ρ ^ (2 * n)) Filter.atTop (nhds 0) := by
      convert h_exp_poly ( 2 + ⌈α⌉₊ ) ( ρ ^ 2 ) ( by rw [ abs_of_nonneg ( sq_nonneg ρ ) ] ; nlinarith ) using 2 ; ring;
    refine' squeeze_zero_norm' _ h_exp_poly_applied;
    filter_upwards [ Filter.eventually_gt_atTop 0 ] with n hn using by rw [ Real.norm_of_nonneg ( by positivity ) ] ; exact mul_le_mul_of_nonneg_right ( by exact_mod_cast Real.rpow_le_rpow_of_exponent_le ( Nat.one_le_cast.mpr hn ) ( show 2 + α ≤ 2 + ⌈α⌉₊ by linarith [ Nat.le_ceil α ] ) ) ( by positivity ) ;
  -- We can use the fact that $(n + 1)^{2 + \alpha} \leq 2^{2 + \alpha} n^{2 + \alpha}$ for all $n \geq 1$.
  have h_bound : ∀ n : ℕ, 1 ≤ n → ((n + 1 : ℝ) ^ (2 + α)) ≤ 2 ^ (2 + α) * (n : ℝ) ^ (2 + α) := by
    intro n hn; rw [ ← Real.mul_rpow ( by positivity ) ( by positivity ) ] ; gcongr ; norm_cast ; linarith;
  refine' squeeze_zero_norm' _ ( by simpa using h_exp_poly_applied.const_mul ( 2 ^ ( 2 + α ) ) );
  filter_upwards [ Filter.eventually_ge_atTop 1 ] with n hn using by rw [ Real.norm_of_nonneg ( by positivity ) ] ; simpa only [ mul_assoc ] using mul_le_mul_of_nonneg_right ( h_bound n hn ) ( by positivity ) ;

