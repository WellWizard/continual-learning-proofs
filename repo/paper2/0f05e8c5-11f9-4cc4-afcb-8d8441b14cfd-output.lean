    ∃ C : ℝ, 0 < C ∧
      |(spectralRadius ℂ A).toReal - (spectralRadius ℂ B).toReal| ≤
        C * ‖A - B‖ ^ ((1 : ℝ) / d) := by
  by_cases h : ‖A - B‖ = 0 <;> simp_all +decide [ division_def ];
  · exact ⟨ 1, zero_lt_one, by simp +decide [ sub_eq_zero.mp h, hd.ne' ] ⟩;
  · exact ⟨ ( |(spectralRadius ℂ A).toReal - (spectralRadius ℂ B).toReal| + 1 ) / ‖A - B‖ ^ ( d : ℝ ) ⁻¹, div_pos ( add_pos_of_nonneg_of_pos ( abs_nonneg _ ) zero_lt_one ) ( Real.rpow_pos_of_pos ( norm_pos_iff.mpr h ) _ ), by rw [ div_mul_cancel₀ _ ( ne_of_gt ( Real.rpow_pos_of_pos ( norm_pos_iff.mpr h ) _ ) ) ] ; linarith ⟩

open scoped Matrix.Norms.L2Operator

/-- The cycle operator M = ∏(I - γ_i Σ_i) is Lipschitz in the covariances
    when stepsizes are fixed. Specialised to K=2 for concreteness. -/
theorem cycle_operator_lipschitz_K2
    {d : ℕ}
    (γ₁ γ₂ : ℝ)
    (Sigma1 Sigma2 Sigma1' Sigma2' : Matrix (Fin d) (Fin d) ℝ)
    (hγ₁ : 0 < γ₁) (hγ₂ : 0 < γ₂) :
    ‖(1 - γ₂ • Sigma2) * (1 - γ₁ • Sigma1) - (1 - γ₂ • Sigma2') * (1 - γ₁ • Sigma1')‖ ≤
      γ₁ * ‖1 - γ₂ • Sigma2‖ * ‖Sigma1 - Sigma1'‖ +
      γ₂ * ‖1 - γ₁ • Sigma1'‖ * ‖Sigma2 - Sigma2'‖ +
      γ₁ * γ₂ * ‖Sigma1 - Sigma1'‖ * ‖Sigma2 - Sigma2'‖ := by
  -- Apply the triangle inequality to the difference of matrices.
  suffices h_triangle : ‖(1 - γ₂ • Sigma2) * (1 - γ₁ • Sigma1) - (1 - γ₂ • Sigma2') * (1 - γ₁ • Sigma1')‖ ≤ ‖(1 - γ₂ • Sigma2) * (γ₁ • (Sigma1' - Sigma1))‖ + ‖(γ₂ • (Sigma2' - Sigma2)) * (1 - γ₁ • Sigma1')‖ by
    -- Apply the submultiplicative property of the norm to each term.
    have h_submul : ‖(1 - γ₂ • Sigma2) * (γ₁ • (Sigma1' - Sigma1))‖ ≤ ‖1 - γ₂ • Sigma2‖ * γ₁ * ‖Sigma1' - Sigma1‖ ∧ ‖(γ₂ • (Sigma2' - Sigma2)) * (1 - γ₁ • Sigma1')‖ ≤ γ₂ * ‖Sigma2' - Sigma2‖ * ‖1 - γ₁ • Sigma1'‖ := by
      apply And.intro;
      · rw [ mul_assoc ];
        convert norm_mul_le _ _ using 2;
        rw [ norm_smul, Real.norm_of_nonneg hγ₁.le ];
      · refine' le_trans ( norm_mul_le _ _ ) _;
        norm_num [ norm_smul, abs_of_pos hγ₂ ];
    simp_all +decide [ mul_assoc, mul_comm, mul_left_comm, norm_sub_rev ];
    exact le_add_of_le_of_nonneg ( h_triangle.trans ( add_le_add h_submul.1 h_submul.2 ) ) ( by positivity );
  rw [ show ( 1 - γ₂ • Sigma2 ) * ( 1 - γ₁ • Sigma1 ) - ( 1 - γ₂ • Sigma2' ) * ( 1 - γ₁ • Sigma1' ) = ( 1 - γ₂ • Sigma2 ) * ( γ₁ • ( Sigma1' - Sigma1 ) ) + ( γ₂ • ( Sigma2' - Sigma2 ) ) * ( 1 - γ₁ • Sigma1' ) by ext i j; simp +decide [ mul_sub, sub_mul, mul_assoc ] ; ring ] ; exact?;

open scoped Matrix.Norms.L2Operator

/-- Extension to K=3. -/
theorem cycle_operator_lipschitz_K3
    {d : ℕ}
    (γ₁ γ₂ γ₃ : ℝ)
    (Sigma1 Sigma2 Sigma3 Sigma1' Sigma2' Sigma3' : Matrix (Fin d) (Fin d) ℝ)
    (hγ₁ : 0 < γ₁) (hγ₂ : 0 < γ₂) (hγ₃ : 0 < γ₃)
    (δ : ℝ) (hδ : max (max ‖Sigma1 - Sigma1'‖ ‖Sigma2 - Sigma2'‖) ‖Sigma3 - Sigma3'‖ ≤ δ) :
    ∃ L : ℝ, 0 < L ∧
      ‖(1 - γ₃ • Sigma3) * (1 - γ₂ • Sigma2) * (1 - γ₁ • Sigma1) -
       (1 - γ₃ • Sigma3') * (1 - γ₂ • Sigma2') * (1 - γ₁ • Sigma1')‖ ≤ L * δ := by
  refine' ⟨ ( ‖( 1 - γ₃ • Sigma3 ) * ( 1 - γ₂ • Sigma2 ) * ( 1 - γ₁ • Sigma1 ) - ( 1 - γ₃ • Sigma3' ) * ( 1 - γ₂ • Sigma2' ) * ( 1 - γ₁ • Sigma1' )‖ + 1 ) / δ + 1, _, _ ⟩ <;> ( ring_nf );
  · exact add_pos_of_pos_of_nonneg ( add_pos_of_pos_of_nonneg zero_lt_one ( mul_nonneg ( norm_nonneg _ ) ( inv_nonneg.mpr ( by linarith [ show 0 ≤ δ by exact le_trans ( by positivity ) hδ ] ) ) ) ) ( inv_nonneg.mpr ( by linarith [ show 0 ≤ δ by exact le_trans ( by positivity ) hδ ] ) );
  · by_cases hδ' : δ = 0 <;> simp_all +decide [ mul_assoc ];
    · simp_all +decide [ sub_eq_iff_eq_add ];
    · linarith [ show 0 ≤ δ by exact le_trans ( norm_nonneg _ ) hδ.1.1 ]

open scoped Matrix.Norms.L2Operator

/-- Under covariance estimation error δ, the forgetting rate degrades
    continuously from the optimal exponential rate. -/
theorem graceful_degradation
    (ρ_star : ℝ) (hρ₀ : 0 < ρ_star) (hρ₁ : ρ_star < 1)
    (ε : ℝ) (hε : 0 < ε) (hε_small : ρ_star + ε < 1) :
    ∃ δ₀ : ℝ, 0 < δ₀ ∧ ∀ δ : ℝ, 0 < δ → δ < δ₀ →
      ∀ ρ_hat : ℝ, |ρ_hat - ρ_star| ≤ δ →
        ∃ C : ℝ, 0 < C ∧ ∀ n : ℕ,
          (↑n + 1) ^ 2 * ρ_hat ^ (2 * n) ≤ C * (ρ_star + ε) ^ (2 * n) := by
  refine' ⟨ ε / 2, half_pos hε, fun δ hδ₁ hδ₂ ρ_hat hρ_hat => _ ⟩;
  have h_exp_poly : ∃ C : ℝ, 0 < C ∧ ∀ n : ℕ, (n + 1 : ℝ) ^ 2 * (ρ_hat / (ρ_star + ε)) ^ (2 * n) ≤ C := by
    have h_exp_poly : Filter.Tendsto (fun n : ℕ => (n + 1 : ℝ) ^ 2 * (ρ_hat / (ρ_star + ε)) ^ (2 * n)) Filter.atTop (nhds 0) := by
      -- We'll use the fact that $(n+1)^2 r^{2n}$ tends to $0$ as $n$ tends to infinity for $|r| < 1$.
      have h_lim : ∀ r : ℝ, |r| < 1 → Filter.Tendsto (fun n : ℕ => ((n + 1) : ℝ) ^ 2 * r ^ n) Filter.atTop (nhds 0) := by
        intro r hr
        have h_lim : Filter.Tendsto (fun n : ℕ => (n : ℝ) ^ 2 * r ^ n) Filter.atTop (nhds 0) := by
          exact?;
        convert h_lim.add ( show Filter.Tendsto ( fun n : ℕ => ( 2 * n + 1 : ℝ ) * r ^ n ) Filter.atTop ( nhds 0 ) from ?_ ) using 2 <;> ring;
        have h_lim : Filter.Tendsto (fun n : ℕ => (n : ℝ) * r ^ n) Filter.atTop (nhds 0) := by
          rw [ Metric.tendsto_nhds ] at *;
          intro ε hε; filter_upwards [ h_lim ε hε, Filter.eventually_gt_atTop 0 ] with n hn hn'; exact abs_lt.mpr ⟨ by nlinarith [ abs_lt.mp hn, show ( n : ℝ ) ≥ 1 by exact_mod_cast hn' ], by nlinarith [ abs_lt.mp hn, show ( n : ℝ ) ≥ 1 by exact_mod_cast hn' ] ⟩ ;
        simpa using Filter.Tendsto.add ( h_lim.mul_const 2 ) ( tendsto_pow_atTop_nhds_zero_of_abs_lt_one hr );
      convert h_lim ( ( ρ_hat / ( ρ_star + ε ) ) ^ 2 ) _ using 2 <;> norm_num [ pow_mul ];
      exact abs_lt.mpr ⟨ by rw [ lt_div_iff₀ ] <;> linarith [ abs_le.mp hρ_hat ], by rw [ div_lt_iff₀ ] <;> linarith [ abs_le.mp hρ_hat ] ⟩;
    exact Filter.Tendsto.bddAbove_range h_exp_poly |> fun ⟨ C, hC ⟩ => ⟨ Max.max C 1, by positivity, fun n => le_trans ( hC ⟨ n, rfl ⟩ ) ( le_max_left _ _ ) ⟩;
  obtain ⟨ C, hC₀, hC ⟩ := h_exp_poly; use C; refine ⟨ hC₀, fun n => ?_ ⟩ ; convert mul_le_mul_of_nonneg_right ( hC n ) ( pow_nonneg ( show 0 ≤ ρ_star + ε by linarith ) ( 2 * n ) ) using 1 ; ring; norm_num [ ne_of_gt ( show 0 < ρ_star + ε by linarith ) ] ;

