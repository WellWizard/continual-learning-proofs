    induction n <;> simp_all +decide [ pow_succ, add_mul, mul_add ];
    rw [ show M = lam • 1 + N by rw [ add_sub_cancel ] ] ; simp_all +decide [ mul_add, add_mul, mul_assoc, smul_smul ] ; ring;
