open scoped Matrix.Norms.L2Operator

/-- The non-forgetting constraint A_i^T Σ_j A_i ≼ Σ_j is equivalent to
    Σ_j - A_i^T Σ_j A_i being positive semidefinite, which is a polynomial
    condition in the stepsizes. -/
theorem nf_constraint_psd
    {d : ℕ}
    (Sigma_i Sigma_j : Matrix (Fin d) (Fin d) ℝ)
    (γ : ℝ)
    (hSigma_i : Sigma_i.PosDef) (hSigma_j : Sigma_j.PosDef)
    (hγ : 0 < γ) :
    let A := (1 : Matrix (Fin d) (Fin d) ℝ) - γ • Sigma_i
    (Sigma_j - Aᵀ * Sigma_j * A).PosSemidef ↔
      ∀ v : Fin d → ℝ, v ⬝ᵥ (Sigma_j - Aᵀ * Sigma_j * A).mulVec v ≥ 0 := by
  simp_all +decide [ Matrix.PosSemidef, Matrix.IsHermitian ];
  simp_all +decide [ Matrix.IsHermitian, Matrix.mul_assoc ];
  intro h; have := hSigma_i.1; have := hSigma_j.1; simp_all +decide [ Matrix.IsHermitian, Matrix.transpose_mul ] ;

