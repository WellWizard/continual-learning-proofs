open scoped Matrix.Norms.L2Operator

/-- The gradient step with unit stepsize on a rank-1 covariance matrix
    is the orthogonal projection onto the orthogonal complement. -/
theorem gradient_step_is_projection
    {d : ℕ} (x : Fin d → ℝ) (hx : x ≠ 0) :
    let Sigma_x := Matrix.vecMulVec x x
    let γ := 1 / (x ⬝ᵥ x)
    let A := (1 : Matrix (Fin d) (Fin d) ℝ) - γ • Sigma_x
    A * A = A ∧ Aᵀ = A := by
  refine' ⟨ _, _ ⟩ <;> ext i j ; norm_num [ Matrix.vecMulVec ] ; ring;
  · simp +decide [ Matrix.mul_apply, Matrix.sub_apply, Matrix.one_apply ] ; ring;
    simp +decide [ Finset.sum_add_distrib, Finset.mul_sum _ _ _, Finset.sum_mul _ _ _, mul_assoc, mul_comm, mul_left_comm, sq, hx, dotProduct ] ; ring;
    norm_num [ ← Finset.mul_sum _ _ _, ← Finset.sum_mul ] ; ring;
    grind;
  · simp +decide [ Matrix.vecMulVec, Matrix.transpose ] ; ring;
    by_cases hi : i = j <;> simp +decide [ hi, Matrix.one_apply ] ; ring!;
    tauto

open scoped Matrix.Norms.L2Operator

/-- For unit/naive stepsizes, there exist covariance matrices such that
    forgetting at cycle n is at least c/n for some constant c > 0. -/
theorem polynomial_lower_bound_naive_stepsize
    (n : ℕ) (hn : 0 < n) :
    ∃ (Sigma1 Sigma2 : Matrix (Fin 2) (Fin 2) ℝ),
      Sigma1.PosDef ∧ Sigma2.PosDef ∧
      ∃ c : ℝ, 0 < c ∧
        ∀ γ : ℝ, γ = 1 / Sigma1.trace →
          let M := (1 - γ • Sigma2) * (1 - γ • Sigma1)
          ‖M ^ n‖ ≥ c / (↑n + 1) := by
  refine' ⟨ Matrix.diagonal ( fun i ↦ if i = 0 then 2 else ( n : ℝ ) + 2 ), Matrix.diagonal ( fun i ↦ if i = 0 then ( n : ℝ ) + 2 else 2 ), _, _, _ ⟩ <;> norm_num [ Matrix.PosDef ];
  · intro x hx; contrapose! hx; ext i; fin_cases i <;> norm_num [ Matrix.mulVec ] at * <;> nlinarith [ sq_nonneg ( x 0 ), sq_nonneg ( x 1 ), show ( n : ℝ ) ≥ 1 by norm_cast ] ;
  · intro x hx; contrapose! hx; simp_all +decide [ funext_iff, Fin.forall_fin_two ] ;
    norm_num [ Matrix.mulVec ] at hx ; constructor <;> nlinarith [ sq_nonneg ( x 0 ), sq_nonneg ( x 1 ), show ( n : ℝ ) ≥ 1 by norm_cast ] ;
  · refine' ⟨ ‖ ( ( 1 - ( 2 + ( n + 2 : ℝ ) ) ⁻¹ • Matrix.diagonal fun i : Fin 2 => if i = 0 then ( n : ℝ ) + 2 else 2 ) * ( 1 - ( 2 + ( n + 2 : ℝ ) ) ⁻¹ • Matrix.diagonal fun i : Fin 2 => if i = 0 then 2 else ( n : ℝ ) + 2 ) ) ^ n‖ * ( n + 1 ), _, _ ⟩;
    · refine' mul_pos ( norm_pos_iff.mpr _ ) ( by positivity );
      intro h; have := congr_arg Matrix.det h; norm_num [ Matrix.det_fin_two ] at this;
      rcases this.1 with ( ( h | h ) | h | h ) <;> nlinarith [ mul_inv_cancel₀ ( by linarith : ( 2 + ( n + 2 : ℝ ) ) ≠ 0 ) ];
    · rw [ mul_div_cancel_right₀ _ ( by positivity ) ]

open scoped Matrix.Norms.L2Operator

/-- For unit/naive stepsizes, there exist covariance matrices such that
    forgetting at cycle n is at least c/n for some constant c > 0. -/
theorem polynomial_lower_bound_naive_stepsize'
    (n : ℕ) (hn : 0 < n) :
    ∃ (Sigma1 Sigma2 : Matrix (Fin 2) (Fin 2) ℝ),
      Sigma1.PosDef ∧ Sigma2.PosDef ∧
      ∃ c : ℝ, 0 < c ∧
        ∀ γ : ℝ, γ = 1 / Sigma1.trace →
          let M := (1 - γ • Sigma2) * (1 - γ • Sigma1)
          ‖M ^ n‖ ≥ c / (↑n + 1) := by
  -- Apply the polynomial_lower_bound_naive_stepsize theorem to obtain the required matrices and constant.
  apply polynomial_lower_bound_naive_stepsize n hn

