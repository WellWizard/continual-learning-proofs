/-
Proved that the weighted sum of logs of terms bounded by 1 in absolute value is non-positive (`stochastic_le_negative_commutative`).
Also proved that the supremum of such sums is non-positive (`stochastic_top_le_negative_commutative`).
Note: The original statements claimed strictly less than 0, but this is false (e.g. if the term is 0, log is 0), so I proved ≤ 0 instead.
Also fixed a syntax error in the `sup'` witness.
-/

import Mathlib

set_option linter.mathlibStandardSet false

open scoped BigOperators
open scoped Real
open scoped Nat
open scoped Classical
open scoped Pointwise

set_option maxHeartbeats 0
set_option maxRecDepth 4000
set_option synthInstance.maxHeartbeats 20000
set_option synthInstance.maxSize 128

set_option relaxedAutoImplicit false
set_option autoImplicit false

noncomputable section

open scoped BigOperators

/-
The weighted sum of logs of terms bounded by 1 in absolute value is non-positive.
-/
theorem stochastic_le_negative_commutative
  (K d : ℕ) [NeZero K] [NeZero d]
  (γ : Fin K → ℝ)                          
  (Λ : Fin K → Fin d → ℝ)                  
  (P : Fin K → ℝ)                          
  (hΛ_pos : ∀ i j, 0 < Λ i j)              
  (hγ_NF : ∀ i j, |1 - γ i * Λ i j| < 1)   
  (hP_pos : ∀ i, 0 < P i)                  
  (hP_sum : ∑ i, P i = 1) :                
  ∀ j, ∑ i, P i * Real.log |1 - γ i * Λ i j| ≤ 0 := by
  intro j
  apply Finset.sum_nonpos
  intro i _
  apply mul_nonpos_of_nonneg_of_nonpos
  · apply le_of_lt (hP_pos i)
  · apply Real.log_nonpos
    · apply abs_nonneg
    · apply le_of_lt (hγ_NF i j)

/-
The maximum (supremum) of the weighted sums of logs is non-positive.
-/
theorem stochastic_top_le_negative_commutative
  (K d : ℕ) [NeZero K] [NeZero d]
  (γ : Fin K → ℝ) (Λ : Fin K → Fin d → ℝ) (P : Fin K → ℝ)
  (hΛ_pos : ∀ i j, 0 < Λ i j)
  (hγ_NF : ∀ i j, |1 - γ i * Λ i j| < 1)
  (hP_pos : ∀ i, 0 < P i) (hP_sum : ∑ i, P i = 1) :
  (Finset.univ.sup' ⟨0, Finset.mem_univ 0⟩
    (fun j => ∑ i, P i * Real.log |1 - γ i * Λ i j|)) ≤ 0 := by
  apply Finset.sup'_le
  intro j _
  apply stochastic_le_negative_commutative K d γ Λ P hΛ_pos hγ_NF hP_pos hP_sum