noncomputable def cyclic_le
  (K d : ℕ) [NeZero K] [NeZero d] (Λ : Fin K → Fin d → ℝ) (γ : Fin K → ℝ) : ℝ :=
  (1 / (K : ℝ)) * Finset.univ.sup' (by
  -- Since $d$ is a positive integer, the universal set $\text{Fin } d$ is nonempty.
  apply Finset.univ_nonempty_iff.mpr; exact ⟨0, NeZero.pos d⟩)
    (fun j => Real.log (|∏ i : Fin K, (1 - γ i * Λ i j)|))

noncomputable def iid_le
  (K d : ℕ) [NeZero K] [NeZero d] (Λ : Fin K → Fin d → ℝ) (γ : Fin K → ℝ) (P : Fin K → ℝ) : ℝ :=
  Finset.univ.sup' (by
  -- Since $K$ is a positive integer, the universal set of `Fin K` is nonempty.
  simp [Finset.Nonempty])
